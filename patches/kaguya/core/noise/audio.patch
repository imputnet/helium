+float BaseAudioContext::JitterAudioData(float data,
+                                        ExecutionContext* context,
+                                        uint64_t coordinate_seed) {
+  if (!base::FeatureList::IsEnabled(blink::features::kKaguyaNoiseAudio)) {
+    return data;
+  }
+
+  if (!context || !context->GetKaguyaNoiseTokens().contains(
+      KaguyaNoiseFeature::kAudio)) {
+    return data;
+  }
+
+  KaguyaNoiseHash content_hash(
+      context->GetKaguyaNoiseTokens().at(KaguyaNoiseFeature::kAudio));
+
+  // Update the hash with audio data for extra entropy. This makes it
+  // harder to identify or remove the noise, similar to how we do
+  // it in canvas.
+  uint64_t data_bits = std::bit_cast<uint64_t>(static_cast<double>(data));
+  content_hash.Update(data_bits);
+
+  KaguyaNoiseHash coordinate_hash(
+      context->GetKaguyaNoiseTokens().at(KaguyaNoiseFeature::kAudio));
+  coordinate_hash.Update(kKaguyaAudioCoordinateNoiseDomain);
+  coordinate_hash.Update(coordinate_seed);
+  coordinate_hash.Update(data_bits);
+
+  // Keep the overall jitter bounded to roughly +/-0.01%. The content component
+  // keeps equal sample values from reading back raw, while the coordinate
+  // component prevents chosen repeated samples from calibrating the exact
+  // target noise away.
+  const float jitter =
+      (GetAudioJitter(content_hash) + GetAudioJitter(coordinate_hash)) * 0.5f;
+
+  return data * (1.0f + jitter);
+}
