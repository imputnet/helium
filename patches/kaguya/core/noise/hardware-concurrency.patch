+constexpr const unsigned kMinNoisedCores = 2;
+constexpr const unsigned kMaxNoisedCores = 16;
+
+std::vector<unsigned> PossibleValuesForCoreCount(unsigned n) {
+  // Clamp the number of cores between [2..=16], as other
+  // configurations are less common.
+  n = std::clamp(n, kMinNoisedCores, kMaxNoisedCores);
+
+  // A machine with a odd number of CPUs is very uncommon.
+  // Floor it to the lower even number.
+  if (n % 2) {
+    n -= 1;
+  }
+
+  // If we can subtract some amount and still end up with
+  // a common CPU count (which is the case for most configurations)
+  // let's add it to the list of possible values.
+  std::vector<unsigned> candidates = {n};
+  if (n > 4) {
+    candidates.push_back(n - 4);
+  }
+
+  if (n > 2) {
+    candidates.push_back(n - 2);
+  }
+
+  return candidates;
+}
+
+unsigned MaybeNoiseCoreCount(ExecutionContext* execution_context, unsigned n) {
+  if (!base::FeatureList::IsEnabled(blink::features::kKaguyaNoiseCpuCores) ||
+      !execution_context ||
+      !execution_context->GetKaguyaNoiseTokens().contains(
+          KaguyaNoiseFeature::kHardware)) {
+    return n;
+  }
+
+  auto token_hash =
+      KaguyaNoiseHash(execution_context->GetKaguyaNoiseTokens().at(
+          KaguyaNoiseFeature::kHardware));
+  token_hash.Update(n);
+
+  auto values = PossibleValuesForCoreCount(n);
+  return values[token_hash.GetValueBelow(values.size())];
+}
+
 }  // namespace
 
