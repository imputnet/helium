+bool MultiContentsView::ShouldShowStatusBar() const {
+  const views::Widget* widget = browser_view_->GetWidget();
+  const bool is_fullscreen = widget && widget->IsFullscreen();
+  return browser_view_->GetIsNormalType() && !is_fullscreen;
+}
