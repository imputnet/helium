+KaguyaStatusBarView* BrowserView::GetKaguyaStatusBar() const {
+  return multi_contents_view_ ? multi_contents_view_->status_bar() : nullptr;
+}
+
+void BrowserView::UpdateKaguyaStatusBar() {
+  UpdateKaguyaStatusBarMode();
+  UpdateKaguyaStatusBarURL();
+}
+
+void BrowserView::UpdateKaguyaStatusBarMode() {
+  auto* status_bar = GetKaguyaStatusBar();
+  if (!status_bar) {
+    return;
+  }
+
+  std::u16string mode = u"OFF";
+  if (GetIsNormalType() &&
+      browser_->profile()->GetPrefs()->GetBoolean(
+          prefs::kKaguyaKeyboardNormalModeEnabled)) {
+    content::WebContents* web_contents =
+        browser_->tab_strip_model()->GetActiveWebContents();
+    views::View* focused_view =
+        GetFocusManager() ? GetFocusManager()->GetFocusedView() : nullptr;
+    LocationBarView* location_bar = GetLocationBarView();
+    const bool location_bar_focused =
+        location_bar && focused_view && location_bar->Contains(focused_view);
+    const bool editable_focused =
+        web_contents && web_contents->IsFocusedElementEditable();
+    mode = (location_bar_focused || editable_focused) ? u"INSERT" : u"NORMAL";
+  }
+
+  status_bar->SetModeText(mode);
+  if (mode != u"NORMAL") {
+    ClearKaguyaStatusBarPendingKey();
+  }
+}
+
+void BrowserView::UpdateKaguyaStatusBarURL() {
+  auto* status_bar = GetKaguyaStatusBar();
+  if (!status_bar) {
+    return;
+  }
+  content::WebContents* web_contents =
+      browser_->tab_strip_model()->GetActiveWebContents();
+  status_bar->SetURL(web_contents ? web_contents->GetLastCommittedURL()
+                                  : GURL());
+}
+
+void BrowserView::SetKaguyaStatusBarPendingKey(
+    const std::u16string& pending_key) {
+  if (kaguya_normal_mode_pending_key_ == pending_key) {
+    return;
+  }
+  kaguya_normal_mode_pending_key_ = pending_key;
+  if (auto* status_bar = GetKaguyaStatusBar()) {
+    status_bar->SetPendingKeyText(pending_key);
+  }
+}
+
+void BrowserView::ClearKaguyaStatusBarPendingKey() {
+  SetKaguyaStatusBarPendingKey(std::u16string());
+}
