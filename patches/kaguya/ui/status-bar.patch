+namespace {
+
+constexpr int kHorizontalPadding = 10;
+constexpr int kLabelGap = 12;
+constexpr int kModeLabelWidth = 64;
+constexpr int kPendingLabelWidth = 28;
+constexpr int kBuildTimeLabelWidth = 190;
+
+}  // namespace
+
+KaguyaStatusBarView::KaguyaStatusBarView() {
+  SetCanProcessEventsWithinSubtree(false);
+  SetBackground(views::CreateSolidBackground(ui::kColorSysOmniboxContainer));
+  SetBorder(views::CreateSolidSidedBorder(gfx::Insets::TLBR(1, 0, 0, 0),
+                                          kColorToolbarSeparator));
+
+  auto* layout = SetLayoutManager(std::make_unique<views::FlexLayout>());
+  layout->SetOrientation(views::LayoutOrientation::kHorizontal)
+      .SetCrossAxisAlignment(views::LayoutAlignment::kCenter)
+      .SetInteriorMargin(gfx::Insets::VH(0, kHorizontalPadding))
+      .SetDefault(views::kMarginsKey, gfx::Insets::TLBR(0, 0, 0, kLabelGap));
+
+  mode_label_ = AddStatusLabel(u"OFF");
+  mode_label_->SetPreferredSize(gfx::Size(kModeLabelWidth, kHeight));
+
+  pending_key_label_ = AddStatusLabel(std::u16string());
+  pending_key_label_->SetPreferredSize(gfx::Size(kPendingLabelWidth, kHeight));
+  pending_key_label_->SetVisible(false);
+
+  build_time_label_ =
+      AddStatusLabel(base::UTF8ToUTF16(std::string("built ") + __DATE__ +
+                                       " " + __TIME__));
+  build_time_label_->SetPreferredSize(gfx::Size(kBuildTimeLabelWidth, kHeight));
+
+  url_label_ = AddStatusLabel(std::u16string());
+  url_label_->SetElideBehavior(gfx::ELIDE_TAIL);
+  url_label_->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+  url_label_->SetProperty(
+      views::kFlexBehaviorKey,
+      views::FlexSpecification(
+          views::MinimumFlexSizeRule::kScaleToMinimum,
+          views::MaximumFlexSizeRule::kUnbounded)
+          .WithWeight(1));
+
+  UpdateLabelColors();
+}
+
+KaguyaStatusBarView::~KaguyaStatusBarView() = default;
+
+void KaguyaStatusBarView::SetModeText(const std::u16string& mode_text) {
+  mode_label_->SetText(mode_text);
+}
+
+void KaguyaStatusBarView::SetPendingKeyText(
+    const std::u16string& pending_key_text) {
+  pending_key_label_->SetText(pending_key_text);
+  pending_key_label_->SetVisible(!pending_key_text.empty());
+  InvalidateLayout();
+}
+
+void KaguyaStatusBarView::ClearPendingKeyText() {
+  SetPendingKeyText(std::u16string());
+}
+
+void KaguyaStatusBarView::SetURL(const GURL& url) {
+  url_label_->SetText(url.is_valid() ? url_formatter::FormatUrl(url)
+                                     : std::u16string());
+}
+
+gfx::Size KaguyaStatusBarView::CalculatePreferredSize(
+    const views::SizeBounds& available_size) const {
+  return gfx::Size(0, kHeight);
+}
+
+void KaguyaStatusBarView::OnThemeChanged() {
+  views::View::OnThemeChanged();
+  UpdateLabelColors();
+}
+
+void KaguyaStatusBarView::UpdateLabelColors() {
+  for (views::Label* label : {mode_label_.get(), pending_key_label_.get(),
+                              build_time_label_.get(), url_label_.get()}) {
+    label->SetBackgroundColor(ui::kColorSysOmniboxContainer);
+    label->SetEnabledColor(kColorTabForegroundActiveFrameActive);
+  }
+}
+
+views::Label* KaguyaStatusBarView::AddStatusLabel(
+    const std::u16string& text) {
+  auto label = std::make_unique<views::Label>(text);
+  label->SetSubpixelRenderingEnabled(false);
+  label->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+  return AddChildView(std::move(label));
+}
