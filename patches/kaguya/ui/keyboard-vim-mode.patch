+// Copyright 2026 The Kaguya Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_VIEWS_KAGUYA_KAGUYA_VIM_MODE_CONTROLLER_H_
+#define CHROME_BROWSER_UI_VIEWS_KAGUYA_KAGUYA_VIM_MODE_CONTROLLER_H_
+
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "base/memory/weak_ptr.h"
+#include "content/public/browser/keyboard_event_processing_result.h"
+#include "ui/base/accelerators/accelerator.h"
+
+class Browser;
+class BrowserView;
+class KaguyaStatusBarView;
+
+namespace content {
+class WebContents;
+}  // namespace content
+
+namespace input {
+struct NativeWebKeyboardEvent;
+}  // namespace input
+
+class KaguyaVimModeController {
+ public:
+  KaguyaVimModeController(BrowserView* browser_view, Browser* browser);
+  KaguyaVimModeController(const KaguyaVimModeController&) = delete;
+  KaguyaVimModeController& operator=(const KaguyaVimModeController&) = delete;
+  ~KaguyaVimModeController();
+
+  content::KeyboardEventProcessingResult HandleKeyEvent(
+      const input::NativeWebKeyboardEvent& event);
+
+  void ActiveWebContentsChanged();
+  void PageURLChanged();
+  void FocusChangedInPage();
+  void UpdateState();
+  void UpdateStatusBar();
+
+ private:
+  enum class Mode {
+    kOff,
+    kNormal,
+    kInsert,
+    kPassthrough,
+    kVisual,
+  };
+
+  content::WebContents* GetActiveWebContents() const;
+  KaguyaStatusBarView* GetStatusBar() const;
+  bool IsAvailable() const;
+  bool IsEditableFocused() const;
+  std::u16string GetModeText() const;
+  void SetMode(Mode mode);
+  void SetPendingKey(const std::u16string& pending_key);
+  void ClearPendingKey();
+  void UpdateStatusBarMode();
+  void UpdateStatusBarURL();
+  void OpenFindBar();
+  bool ShouldSuppressCharForKey(
+      const input::NativeWebKeyboardEvent& event,
+      bool has_non_shift_modifier) const;
+  content::KeyboardEventProcessingResult HandleConsumedKey(
+      const input::NativeWebKeyboardEvent& event,
+      bool has_non_shift_modifier);
+  content::KeyboardEventProcessingResult HandleNormalKey(
+      const input::NativeWebKeyboardEvent& event,
+      bool has_shift,
+      bool has_non_shift_modifier);
+  content::KeyboardEventProcessingResult HandleVisualKey(
+      const input::NativeWebKeyboardEvent& event,
+      bool has_shift,
+      bool has_non_shift_modifier);
+  content::KeyboardEventProcessingResult DispatchBrowserShortcut(
+      const input::NativeWebKeyboardEvent& event);
+
+  raw_ptr<BrowserView> browser_view_;
+  raw_ptr<Browser> browser_;
+  Mode mode_ = Mode::kNormal;
+  bool suppress_next_char_ = false;
+  std::u16string pending_key_;
+  base::WeakPtrFactory<KaguyaVimModeController> weak_factory_{this};
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_KAGUYA_KAGUYA_VIM_MODE_CONTROLLER_H_
