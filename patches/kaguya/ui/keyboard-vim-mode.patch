+namespace {
+
+bool IsKeyDown(const input::NativeWebKeyboardEvent& event) {
+  return event.GetType() == blink::WebInputEvent::Type::kRawKeyDown ||
+         event.GetType() == blink::WebInputEvent::Type::kKeyDown;
+}
+
+}  // namespace
+
+KaguyaVimModeController::KaguyaVimModeController(BrowserView* browser_view,
+                                                 Browser* browser)
+    : browser_view_(browser_view), browser_(browser) {}
+
+KaguyaVimModeController::~KaguyaVimModeController() = default;
+
+content::KeyboardEventProcessingResult KaguyaVimModeController::HandleKeyEvent(
+    const input::NativeWebKeyboardEvent& event) {
+  if (!IsAvailable()) {
+    SetMode(Mode::kOff);
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+  }
+
+  content::WebContents* web_contents = GetActiveWebContents();
+  if (!web_contents || web_contents->IsShowingContextMenu()) {
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+  }
+
+  UpdateState();
+  if (mode_ == Mode::kOff) {
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+  }
+
+  if (!IsKeyDown(event)) {
+    if (event.GetType() == blink::WebInputEvent::Type::kChar &&
+        suppress_next_char_) {
+      suppress_next_char_ = false;
+      return content::KeyboardEventProcessingResult::HANDLED;
+    }
+
+    if (mode_ == Mode::kInsert || mode_ == Mode::kPassthrough) {
+      return content::KeyboardEventProcessingResult::NOT_HANDLED;
+    }
+
+    return content::KeyboardEventProcessingResult::HANDLED;
+  }
+
+  const bool has_shift =
+      event.GetModifiers() & blink::WebInputEvent::kShiftKey;
+  const bool has_non_shift_modifier =
+      event.GetModifiers() &
+      (blink::WebInputEvent::kControlKey | blink::WebInputEvent::kAltKey |
+       blink::WebInputEvent::kMetaKey);
+
+  if (mode_ == Mode::kInsert) {
+    if (!has_non_shift_modifier && !has_shift &&
+        event.windows_key_code == ui::VKEY_ESCAPE) {
+      web_contents->ClearFocusedElement();
+      SetMode(Mode::kNormal);
+      return HandleConsumedKey(event, has_non_shift_modifier);
+    }
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+  }
+
+  if (mode_ == Mode::kPassthrough) {
+    if (!has_non_shift_modifier && !has_shift &&
+        event.windows_key_code == ui::VKEY_ESCAPE) {
+      SetMode(Mode::kNormal);
+      return HandleConsumedKey(event, has_non_shift_modifier);
+    }
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+  }
+
+  if (mode_ == Mode::kVisual) {
+    return HandleVisualKey(event, has_shift, has_non_shift_modifier);
+  }
+
+  return HandleNormalKey(event, has_shift, has_non_shift_modifier);
+}
+
+void KaguyaVimModeController::ActiveWebContentsChanged() {
+  UpdateState();
+  UpdateStatusBar();
+}
+
+void KaguyaVimModeController::PageURLChanged() {
+  UpdateStatusBarURL();
+}
+
+void KaguyaVimModeController::FocusChangedInPage() {
+  UpdateState();
+}
+
+void KaguyaVimModeController::UpdateState() {
+  if (!IsAvailable()) {
+    SetMode(Mode::kOff);
+    return;
+  }
+
+  if (mode_ == Mode::kOff) {
+    SetMode(Mode::kNormal);
+    return;
+  }
+
+  const bool editable_focused = IsEditableFocused();
+  if (editable_focused && mode_ == Mode::kNormal) {
+    SetMode(Mode::kInsert);
+    return;
+  }
+
+  if (!editable_focused && mode_ == Mode::kInsert) {
+    SetMode(Mode::kNormal);
+    return;
+  }
+
+  UpdateStatusBarMode();
+}
+
+void KaguyaVimModeController::UpdateStatusBar() {
+  UpdateStatusBarMode();
+  UpdateStatusBarURL();
+}
+
+content::WebContents* KaguyaVimModeController::GetActiveWebContents() const {
+  return browser_->tab_strip_model()->GetActiveWebContents();
+}
+
+KaguyaStatusBarView* KaguyaVimModeController::GetStatusBar() const {
+  return browser_view_->GetKaguyaStatusBar();
+}
+
+bool KaguyaVimModeController::IsAvailable() const {
+  return !browser_->is_type_app() && !browser_->is_type_app_popup() &&
+         browser_view_->GetIsNormalType();
+}
+
+bool KaguyaVimModeController::IsEditableFocused() const {
+  content::WebContents* web_contents = GetActiveWebContents();
+  return web_contents && web_contents->IsFocusedElementEditable();
+}
+
+std::u16string KaguyaVimModeController::GetModeText() const {
+  switch (mode_) {
+    case Mode::kOff:
+      return u"OFF";
+    case Mode::kInsert:
+      return u"INSERT";
+    case Mode::kPassthrough:
+      return u"PASSTHRU";
+    case Mode::kVisual:
+      return u"VISUAL";
+    case Mode::kNormal:
+      return u"NORMAL";
+  }
+  return u"NORMAL";
+}
+
+void KaguyaVimModeController::SetMode(Mode mode) {
+  if (mode_ == mode) {
+    UpdateStatusBarMode();
+    return;
+  }
+
+  const bool was_visual = mode_ == Mode::kVisual;
+  mode_ = mode;
+  ClearPendingKey();
+
+  if (was_visual && mode != Mode::kVisual) {
+    if (content::WebContents* web_contents = GetActiveWebContents()) {
+      web_contents->CollapseSelection();
+    }
+  }
+
+  UpdateStatusBarMode();
+}
+
+void KaguyaVimModeController::SetPendingKey(
+    const std::u16string& pending_key) {
+  if (pending_key_ == pending_key) {
+    return;
+  }
+  pending_key_ = pending_key;
+  if (KaguyaStatusBarView* status_bar = GetStatusBar()) {
+    status_bar->SetPendingKeyText(pending_key);
+  }
+}
+
+void KaguyaVimModeController::ClearPendingKey() {
+  SetPendingKey(std::u16string());
+}
+
+void KaguyaVimModeController::UpdateStatusBarMode() {
+  if (KaguyaStatusBarView* status_bar = GetStatusBar()) {
+    status_bar->SetModeText(GetModeText());
+  }
+}
+
+void KaguyaVimModeController::UpdateStatusBarURL() {
+  if (KaguyaStatusBarView* status_bar = GetStatusBar()) {
+    content::WebContents* web_contents = GetActiveWebContents();
+    status_bar->SetURL(web_contents ? web_contents->GetLastCommittedURL()
+                                    : GURL());
+  }
+}
+
+void KaguyaVimModeController::OpenFindBar() {
+  if (!IsAvailable()) {
+    return;
+  }
+
+  FindBarController* find_bar_controller =
+      browser_->GetFeatures().GetFindBarController();
+  find_bar_controller->Show();
+  find_bar_controller->SetText(std::u16string());
+}
+
+bool KaguyaVimModeController::ShouldSuppressCharForKey(
+    const input::NativeWebKeyboardEvent& event,
+    bool has_non_shift_modifier) const {
+  return !has_non_shift_modifier &&
+         (event.windows_key_code == ui::VKEY_SPACE ||
+          event.windows_key_code == ui::VKEY_OEM_2 ||
+          (event.windows_key_code >= ui::VKEY_0 &&
+           event.windows_key_code <= ui::VKEY_9) ||
+          (event.windows_key_code >= ui::VKEY_A &&
+           event.windows_key_code <= ui::VKEY_Z));
+}
+
+content::KeyboardEventProcessingResult
+KaguyaVimModeController::HandleConsumedKey(
+    const input::NativeWebKeyboardEvent& event,
+    bool has_non_shift_modifier) {
+  if (ShouldSuppressCharForKey(event, has_non_shift_modifier)) {
+    suppress_next_char_ = true;
+  }
+  return content::KeyboardEventProcessingResult::HANDLED;
+}
+
+content::KeyboardEventProcessingResult KaguyaVimModeController::HandleNormalKey(
+    const input::NativeWebKeyboardEvent& event,
+    bool has_shift,
+    bool has_non_shift_modifier) {
+  if (!has_shift && !has_non_shift_modifier &&
+      event.windows_key_code == ui::VKEY_V) {
+    SetMode(Mode::kVisual);
+    return HandleConsumedKey(event, has_non_shift_modifier);
+  }
+
+  if ((event.GetModifiers() & blink::WebInputEvent::kControlKey) &&
+      event.windows_key_code == ui::VKEY_V) {
+    SetMode(Mode::kPassthrough);
+    return HandleConsumedKey(event, has_non_shift_modifier);
+  }
+
+  if (has_non_shift_modifier) {
+    ClearPendingKey();
+    return DispatchBrowserShortcut(event);
+  }
+
+  int command_id = 0;
+  switch (event.windows_key_code) {
+    case ui::VKEY_I:
+    case ui::VKEY_A:
+      SetMode(Mode::kInsert);
+      return HandleConsumedKey(event, has_non_shift_modifier);
+    case ui::VKEY_J:
+      command_id = has_shift ? IDC_BACK : IDC_KAGUYA_SCROLL_LINE_DOWN;
+      break;
+    case ui::VKEY_K:
+      command_id = has_shift ? IDC_FORWARD : IDC_KAGUYA_SCROLL_LINE_UP;
+      break;
+    case ui::VKEY_SPACE:
+      command_id = has_shift ? IDC_KAGUYA_SCROLL_PAGE_UP
+                             : IDC_KAGUYA_SCROLL_PAGE_DOWN;
+      break;
+    case ui::VKEY_H:
+      command_id = has_shift ? IDC_SELECT_PREVIOUS_TAB : 0;
+      break;
+    case ui::VKEY_L:
+      command_id = has_shift ? IDC_SELECT_NEXT_TAB : 0;
+      break;
+    case ui::VKEY_G:
+      if (has_shift) {
+        command_id = IDC_KAGUYA_SCROLL_TO_BOTTOM;
+      } else if (pending_key_ == u"g") {
+        command_id = IDC_KAGUYA_SCROLL_TO_TOP;
+      } else {
+        SetPendingKey(u"g");
+        return HandleConsumedKey(event, has_non_shift_modifier);
+      }
+      break;
+    case ui::VKEY_O:
+      command_id = has_shift ? 0 : IDC_FOCUS_LOCATION;
+      break;
+    case ui::VKEY_OEM_2:
+      if (!has_shift) {
+        base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+            FROM_HERE,
+            base::BindOnce(&KaguyaVimModeController::OpenFindBar,
+                           weak_factory_.GetWeakPtr()));
+        ClearPendingKey();
+        return HandleConsumedKey(event, has_non_shift_modifier);
+      }
+      command_id = 0;
+      break;
+    case ui::VKEY_R:
+      command_id = has_shift ? 0 : IDC_RELOAD;
+      break;
+    case ui::VKEY_T:
+      command_id = has_shift ? 0 : IDC_NEW_TAB;
+      break;
+    case ui::VKEY_X:
+      command_id = has_shift ? 0 : IDC_CLOSE_TAB;
+      break;
+    case ui::VKEY_U:
+      command_id = has_shift ? 0 : IDC_RESTORE_TAB;
+      break;
+    default:
+      break;
+  }
+
+  if (!command_id) {
+    ClearPendingKey();
+    return HandleConsumedKey(event, has_non_shift_modifier);
+  }
+
+  ClearPendingKey();
+  browser_->command_controller()->ExecuteCommand(command_id);
+  return HandleConsumedKey(event, has_non_shift_modifier);
+}
+
+content::KeyboardEventProcessingResult KaguyaVimModeController::HandleVisualKey(
+    const input::NativeWebKeyboardEvent& event,
+    bool has_shift,
+    bool has_non_shift_modifier) {
+  if (!has_shift && !has_non_shift_modifier &&
+      event.windows_key_code == ui::VKEY_ESCAPE) {
+    SetMode(Mode::kNormal);
+    return HandleConsumedKey(event, has_non_shift_modifier);
+  }
+
+  if (!has_shift && !has_non_shift_modifier &&
+      event.windows_key_code == ui::VKEY_V) {
+    SetMode(Mode::kNormal);
+    return HandleConsumedKey(event, has_non_shift_modifier);
+  }
+
+  if (!has_shift && !has_non_shift_modifier &&
+      event.windows_key_code == ui::VKEY_Y) {
+    browser_->command_controller()->ExecuteCommand(IDC_COPY);
+    SetMode(Mode::kNormal);
+    return HandleConsumedKey(event, has_non_shift_modifier);
+  }
+
+  if (has_non_shift_modifier) {
+    ClearPendingKey();
+    return DispatchBrowserShortcut(event);
+  }
+
+  content::WebContents* web_contents = GetActiveWebContents();
+  switch (event.windows_key_code) {
+    case ui::VKEY_H:
+      web_contents->AdjustSelectionByCharacterOffset(0, -1, false);
+      break;
+    case ui::VKEY_L:
+      web_contents->AdjustSelectionByCharacterOffset(0, 1, false);
+      break;
+    case ui::VKEY_K:
+      web_contents->ScrollLineUp();
+      break;
+    case ui::VKEY_J:
+      web_contents->ScrollLineDown();
+      break;
+    case ui::VKEY_G:
+      if (has_shift) {
+        web_contents->ScrollToBottomOfDocument();
+      } else if (pending_key_ == u"g") {
+        web_contents->ScrollToTopOfDocument();
+        ClearPendingKey();
+      } else {
+        SetPendingKey(u"g");
+        return HandleConsumedKey(event, has_non_shift_modifier);
+      }
+      break;
+    case ui::VKEY_SPACE:
+      web_contents->ScrollLineDown();
+      break;
+    default:
+      return HandleConsumedKey(event, has_non_shift_modifier);
+  }
+
+  return HandleConsumedKey(event, has_non_shift_modifier);
+}
+
+content::KeyboardEventProcessingResult
+KaguyaVimModeController::DispatchBrowserShortcut(
+    const input::NativeWebKeyboardEvent& event) {
+  if (!browser_view_->browser_shortcut_service_) {
+#if !defined(OFFICIAL_BUILD)
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+#else
+    return content::KeyboardEventProcessingResult::HANDLED;
+#endif
+  }
+
+  ui::Accelerator accelerator =
+      ui::GetAcceleratorFromNativeWebKeyboardEvent(event);
+  std::optional<int> command_id =
+      browser_view_->browser_shortcut_service_->FindCommandForAccelerator(
+          accelerator);
+  if (!command_id) {
+#if !defined(OFFICIAL_BUILD)
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+#else
+    return content::KeyboardEventProcessingResult::HANDLED;
+#endif
+  }
+
+  browser_->command_controller()->ExecuteCommand(*command_id);
+  return content::KeyboardEventProcessingResult::HANDLED;
+}
