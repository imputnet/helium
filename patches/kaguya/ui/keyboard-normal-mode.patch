+content::KeyboardEventProcessingResult BrowserView::HandleKaguyaNormalModeKey(
+    const NativeWebKeyboardEvent& event) {
+  if (browser_->is_type_app() || browser_->is_type_app_popup() ||
+      !browser_->profile()->GetPrefs()->GetBoolean(
+          prefs::kKaguyaKeyboardNormalModeEnabled)) {
+    kaguya_normal_mode_pending_g_ = false;
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+  }
+
+  content::WebContents* web_contents =
+      browser_->tab_strip_model()->GetActiveWebContents();
+  if (!web_contents || web_contents->IsShowingContextMenu()) {
+    kaguya_normal_mode_pending_g_ = false;
+    return content::KeyboardEventProcessingResult::NOT_HANDLED;
+  }
+
+  if (event.GetType() != blink::WebInputEvent::Type::kRawKeyDown) {
+    kaguya_normal_mode_pending_g_ = false;
+    return content::KeyboardEventProcessingResult::HANDLED;
+  }
+
+  const bool has_shift =
+      event.GetModifiers() & blink::WebInputEvent::kShiftKey;
+  const bool has_non_shift_modifier =
+      event.GetModifiers() &
+      (blink::WebInputEvent::kControlKey | blink::WebInputEvent::kAltKey |
+       blink::WebInputEvent::kMetaKey);
+
+  if (web_contents->IsFocusedElementEditable()) {
+    kaguya_normal_mode_pending_g_ = false;
+    if (!has_non_shift_modifier && !has_shift &&
+        event.windows_key_code == ui::VKEY_ESCAPE) {
+      web_contents->ClearFocusedElement();
+      return content::KeyboardEventProcessingResult::HANDLED;
+    }
+    return content::KeyboardEventProcessingResult::HANDLED;
+  }
+
+  if (has_non_shift_modifier) {
+    kaguya_normal_mode_pending_g_ = false;
+    return content::KeyboardEventProcessingResult::HANDLED;
+  }
+
+  int command_id = 0;
+  switch (event.windows_key_code) {
+    case ui::VKEY_J:
+      command_id = has_shift ? IDC_BACK
+                             : IDC_KAGUYA_SCROLL_LINE_DOWN;
+      break;
+    case ui::VKEY_K:
+      command_id = has_shift ? IDC_FORWARD
+                             : IDC_KAGUYA_SCROLL_LINE_UP;
+      break;
+    case ui::VKEY_SPACE:
+      command_id = has_shift ? IDC_KAGUYA_SCROLL_PAGE_UP
+                             : IDC_KAGUYA_SCROLL_PAGE_DOWN;
+      break;
+    case ui::VKEY_H:
+      command_id = has_shift ? IDC_SELECT_PREVIOUS_TAB : 0;
+      break;
+    case ui::VKEY_L:
+      command_id = has_shift ? IDC_SELECT_NEXT_TAB : 0;
+      break;
+    case ui::VKEY_G:
+      if (has_shift) {
+        command_id = IDC_KAGUYA_SCROLL_TO_BOTTOM;
+      } else if (kaguya_normal_mode_pending_g_) {
+        command_id = IDC_KAGUYA_SCROLL_TO_TOP;
+      } else {
+        kaguya_normal_mode_pending_g_ = true;
+        return content::KeyboardEventProcessingResult::HANDLED;
+      }
+      break;
+    case ui::VKEY_O:
+      command_id = has_shift ? 0 : IDC_FOCUS_LOCATION;
+      break;
+    case ui::VKEY_OEM_2:
+      command_id = has_shift ? 0 : IDC_FIND;
+      break;
+    case ui::VKEY_R:
+      command_id = has_shift ? 0 : IDC_RELOAD;
+      break;
+    case ui::VKEY_T:
+      command_id = has_shift ? 0 : IDC_NEW_TAB;
+      break;
+    case ui::VKEY_X:
+      command_id = has_shift ? 0 : IDC_CLOSE_TAB;
+      break;
+    case ui::VKEY_U:
+      command_id = has_shift ? 0 : IDC_RESTORE_TAB;
+      break;
+    default:
+      break;
+  }
+
+  if (!command_id) {
+    kaguya_normal_mode_pending_g_ = false;
+    return content::KeyboardEventProcessingResult::HANDLED;
+  }
+
+  kaguya_normal_mode_pending_g_ = false;
+  browser_->command_controller()->ExecuteCommand(command_id);
+  return content::KeyboardEventProcessingResult::HANDLED;
+}
