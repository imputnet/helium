+void ToolbarView::OnLocationBarIsCenteredChanged() {
+  InvalidateLayout();
+}
+
+void ToolbarView::MaybeNarrowLocationBar() {
+  if (ShouldDisplayToolbarTabStrip()) {
+    return;
+  }
+
+  if (!location_bar_is_centered_.GetValue()) {
+    return;
+  }
+
+  if (display_mode_ != DisplayMode::kNormal || !location_bar_view_ ||
+      !location_bar_view_->GetVisible()) {
+    return;
+  }
+
+  const int toolbar_width = width();
+  if (toolbar_width < 700) {
+    return;
+  }
+
+  double margin_pct = 0.05;
+  if (toolbar_width >= 1000) {
+    margin_pct = 0.12;
+  } else if (toolbar_width >= 850) {
+    margin_pct = 0.09;
+  }
+
+  gfx::Rect bounds = location_bar_view_->bounds();
+  const int total_margin = static_cast<int>(toolbar_width * margin_pct);
+
+  int new_width =
+      std::min(bounds.width() - total_margin, kCenteredLocationBarMaxWidth);
+  new_width = std::max(new_width, location_bar_view_->GetMinimumSize().width());
+
+  int desired_x = (toolbar_width - new_width) / 2;
+  // Give the left clamp slightly more slack so the location bar stays centered
+  // to the toolbar width, not the remaining toolbar space, when side items differ.
+  int left_limit = bounds.x() + total_margin / 3;
+  int right_limit = bounds.x() + bounds.width() - new_width - total_margin / 2;
+  if (left_limit <= right_limit) {
+    desired_x = std::clamp(desired_x, left_limit, right_limit);
+  } else {
+    desired_x = bounds.x() + (bounds.width() - new_width) / 2;
+  }
+  bounds.set_x(desired_x);
+  bounds.set_width(new_width);
+
+  location_bar_view_->SetBoundsRect(bounds);
+}
