--- src.orig/chrome/browser/ui/ui_features.cc
+++ src/chrome/browser/ui/ui_features.cc
@@ -18,6 +18,13 @@
 
 namespace features {
 
+// Anchored tabs: tab-group centric tab renaming, hibernation, and restore.
+BASE_FEATURE(kHeliumAnchoredTabs, base::FEATURE_ENABLED_BY_DEFAULT);
+
+bool IsHeliumAnchoredTabsEnabled() {
+  return base::FeatureList::IsEnabled(kHeliumAnchoredTabs);
+}
+
 // Automatic location bar width in compact layout
 BASE_FEATURE(kHeliumCompactLocationWidth, base::FEATURE_DISABLED_BY_DEFAULT);
 
