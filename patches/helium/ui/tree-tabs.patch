+    tabs_to_move.push_back(tab_strip_model_->GetTabAtIndex(index));
+  }
+  if (!std::ranges::contains(tabs_to_move, source_tab)) {
+    tabs_to_move.push_back(source_tab);
+  }
+  std::erase_if(tabs_to_move, [&](tabs::TabInterface* tab) {
+    return std::ranges::any_of(tabs_to_move, [&](tabs::TabInterface* other) {
+      return tab != other && tree_controller->IsDescendantOf(tab, other);
+    });
+  });
