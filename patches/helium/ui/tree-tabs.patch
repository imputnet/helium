+      suppressed_helium_tab_tree_controller_;
+  auto* browser_window =
+      source_tab ? source_tab->GetBrowserWindowInterface() : nullptr;
+  if (!source_tab || !browser_window ||
+      HeliumTabTreeController::From(browser_window) != tree_controller) {
+    return;
