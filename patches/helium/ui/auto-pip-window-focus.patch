+void AutoPictureInPictureTabStripObserverHelper::OnBrowserRemoved(
+    Browser* browser) {
+  if (IsActivationChangeForObservedTab(browser)) {
+    weak_ptr_factory_.InvalidateWeakPtrs();
+  }
+}
+
+void AutoPictureInPictureTabStripObserverHelper::OnBrowserSetLastActive(
+    Browser* browser) {
+  UpdateAndNotifyIfBrowserActivationChanged(browser);
+}
+
+void AutoPictureInPictureTabStripObserverHelper::OnBrowserNoLongerActive(
+    Browser* browser) {
+  if (!IsActivationChangeForObservedTab(browser)) {
+    return;
+  }
+
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&AutoPictureInPictureTabStripObserverHelper::
+                         UpdateAndNotifyIfFocusLossShouldTriggerAutoPip,
+                     weak_ptr_factory_.GetWeakPtr()));
+}
+
+bool AutoPictureInPictureTabStripObserverHelper::
+    IsActivationChangeForObservedTab(Browser* browser) const {
+  auto* current_tab_strip_model = GetCurrentTabStripModel();
+  return browser->tab_strip_model() == observed_tab_strip_model_ ||
+         browser->tab_strip_model() == current_tab_strip_model;
+}
+
+void AutoPictureInPictureTabStripObserverHelper::
+    UpdateAndNotifyIfBrowserActivationChanged(Browser* browser) {
+  if (!IsActivationChangeForObservedTab(browser)) {
+    return;
+  }
+
+  UpdateAndNotifyIfTabActivationChanged();
+}
+
+void AutoPictureInPictureTabStripObserverHelper::
+    UpdateAndNotifyIfFocusLossShouldTriggerAutoPip() {
+  if (ShouldIgnoreFocusLossForDifferentDisplay()) {
+    return;
+  }
+
+  UpdateAndNotifyIfTabActivationChanged();
+}
+
+void AutoPictureInPictureTabStripObserverHelper::
+    UpdateAndNotifyIfTabActivationChanged() {
+  auto* current_tab_strip_model = GetCurrentTabStripModel();
+  if (current_tab_strip_model != observed_tab_strip_model_) {
+    ObserveTabStripModel(current_tab_strip_model);
+  }
+
