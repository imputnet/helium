+std::optional<int64_t> GetBrowserDisplayId(Browser* browser) {
+  if (!browser || !browser->window()) {
+    return std::nullopt;
+  }
+
+  auto* screen = display::Screen::Get();
+  if (!screen) {
+    return std::nullopt;
+  }
+
+  const display::Display display =
+      screen->GetDisplayNearestWindow(browser->window()->GetNativeWindow());
+  if (!display.is_valid()) {
+    return std::nullopt;
+  }
+
+  return display.id();
+}
+
+std::optional<int64_t> GetActiveBrowserDisplayId() {
+  Browser* active_browser = chrome::FindLastActive();
+  if (!active_browser || !active_browser->IsActive()) {
+    return std::nullopt;
+  }
+
+  return GetBrowserDisplayId(active_browser);
+}
+
+std::optional<int64_t> GetCursorDisplayId() {
+  auto* screen = display::Screen::Get();
+  if (!screen) {
+    return std::nullopt;
+  }
+
+  const display::Display display =
+      screen->GetDisplayNearestPoint(screen->GetCursorScreenPoint());
+  if (!display.is_valid()) {
+    return std::nullopt;
+  }
+
+  return display.id();
+}
+
+std::optional<int64_t> GetFocusedDisplayIdForAutoPipSuppression() {
+  std::optional<int64_t> focused_display_id = GetActiveBrowserDisplayId();
+  if (focused_display_id) {
+    return focused_display_id;
+  }
+
+#if BUILDFLAG(IS_MAC)
+  focused_display_id = picture_in_picture::GetFocusedApplicationDisplayId();
+  if (focused_display_id) {
+    return focused_display_id;
+  }
+#endif
+
+  return GetCursorDisplayId();
+}
+
+bool AreKnownDifferentDisplays(std::optional<int64_t> first_display_id,
+                               std::optional<int64_t> second_display_id) {
+  return first_display_id && second_display_id &&
+         *first_display_id != *second_display_id;
+}
+
+bool IsAutoPictureInPictureOnFocusLossEnabled(
+    content::WebContents* web_contents) {
+  Browser* browser = chrome::FindBrowserWithTab(web_contents);
+  if (!browser) {
+    return true;
+  }
+
+  return browser->profile()->GetPrefs()->GetBoolean(
+      prefs::kHeliumAutoPictureInPictureOnFocusLoss);
+}
