+std::optional<int64_t> GetBrowserDisplayId(Browser* browser) {
+  if (!browser || !browser->window()) {
+    return std::nullopt;
+  }
+
+  auto* screen = display::Screen::Get();
+  if (!screen) {
+    return std::nullopt;
+  }
+
+  const display::Display display =
+      screen->GetDisplayNearestWindow(browser->window()->GetNativeWindow());
+  if (!display.is_valid()) {
+    return std::nullopt;
+  }
+
+  return display.id();
+}
+
+std::optional<int64_t> GetActiveBrowserDisplayId() {
+  Browser* active_browser = chrome::FindLastActive();
+  if (!active_browser || !active_browser->IsActive()) {
+    return std::nullopt;
+  }
+
+  return GetBrowserDisplayId(active_browser);
+}
+
+#if BUILDFLAG(IS_MAC)
+std::optional<int64_t> GetTopmostOtherApplicationWindowDisplayId() {
+  auto* screen = display::Screen::Get();
+  if (!screen) {
+    return std::nullopt;
+  }
+
+  base::apple::ScopedCFTypeRef<CFArrayRef> window_infos(
+      CGWindowListCopyWindowInfo(
+          kCGWindowListOptionOnScreenOnly | kCGWindowListExcludeDesktopElements,
+          kCGNullWindowID));
+  if (!window_infos) {
+    return std::nullopt;
+  }
+
+  const int current_process_id = base::GetCurrentProcId();
+  const CFIndex count = CFArrayGetCount(window_infos.get());
+  for (CFIndex index = 0; index < count; ++index) {
+    CFDictionaryRef window_info = reinterpret_cast<CFDictionaryRef>(
+        CFArrayGetValueAtIndex(window_infos.get(), index));
+    if (!window_info) {
+      continue;
+    }
+
+    CFNumberRef layer_ref = reinterpret_cast<CFNumberRef>(
+        CFDictionaryGetValue(window_info, kCGWindowLayer));
+    int layer = 0;
+    if (!layer_ref || !CFNumberGetValue(layer_ref, kCFNumberIntType, &layer) ||
+        layer != 0) {
+      continue;
+    }
+
+    CFNumberRef owner_process_id_ref = reinterpret_cast<CFNumberRef>(
+        CFDictionaryGetValue(window_info, kCGWindowOwnerPID));
+    int owner_process_id = 0;
+    if (!owner_process_id_ref ||
+        !CFNumberGetValue(owner_process_id_ref, kCFNumberIntType,
+                          &owner_process_id) ||
+        owner_process_id == current_process_id) {
+      continue;
+    }
+
+    CFDictionaryRef bounds_ref = reinterpret_cast<CFDictionaryRef>(
+        CFDictionaryGetValue(window_info, kCGWindowBounds));
+    CGRect bounds = CGRectZero;
+    if (!bounds_ref ||
+        !CGRectMakeWithDictionaryRepresentation(bounds_ref, &bounds) ||
+        CGRectIsEmpty(bounds)) {
+      continue;
+    }
+
+    const gfx::Rect window_bounds(static_cast<int>(bounds.origin.x),
+                                  static_cast<int>(bounds.origin.y),
+                                  static_cast<int>(bounds.size.width),
+                                  static_cast<int>(bounds.size.height));
+    const display::Display display = screen->GetDisplayMatching(window_bounds);
+    if (!display.is_valid()) {
+      continue;
+    }
+
+    return display.id();
+  }
+
+  return std::nullopt;
+}
+#endif
