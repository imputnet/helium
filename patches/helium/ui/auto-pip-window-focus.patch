+std::optional<int64_t> GetFocusedDisplayIdForAutoPipSuppression() {
+  std::optional<int64_t> focused_display_id = GetActiveBrowserDisplayId();
+  if (focused_display_id) {
+    return focused_display_id;
+  }
+
+#if BUILDFLAG(IS_MAC)
+  focused_display_id = GetTopmostOtherApplicationWindowDisplayId();
+  if (focused_display_id) {
+    return focused_display_id;
+  }
+#endif
+
+  return GetCursorDisplayId();
+}
+
+bool AreKnownDifferentDisplays(std::optional<int64_t> first_display_id,
+                               std::optional<int64_t> second_display_id) {
+  return first_display_id && second_display_id &&
+         *first_display_id != *second_display_id;
+}
