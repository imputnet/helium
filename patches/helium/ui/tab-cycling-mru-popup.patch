 void BrowserView::StopTabCycling() {
+  TabStripModel* model = browser()->tab_strip_model();
+
+  if (tab_cycling_popup_) {
+    const int selected = tab_cycling_popup_->GetSelectedTabIndex();
+    tab_cycling_popup_->GetWidget()->Close();
+    tab_cycling_popup_ = nullptr;
+
