+namespace {
+
+std::set<std::string>& OfferedReports() {
+  static base::NoDestructor<std::set<std::string>> reports;
+  return *reports;
+}
+
+crashpad::CrashReportDatabase* GetDatabase() {
+  return crash_reporter::internal::GetCrashReportDatabase();
+}
+
+bool CrashUploadsDisabledByPolicy() {
+  return crash_reporter::UploadsDisabledByPolicy();
+}
+
+bool ParseUUID(const std::string& local_id, crashpad::UUID* uuid) {
+  return uuid->InitializeFromString(local_id);
+}
+
+void DeleteReport(const std::string& local_id) {
+  crashpad::CrashReportDatabase* database = GetDatabase();
+  crashpad::UUID uuid;
+  if (database && ParseUUID(local_id, &uuid)) {
+    database->DeleteReport(uuid);
+  }
+}
+
+void RequestReportUpload(const std::string& local_id) {
+  crashpad::CrashReportDatabase* database = GetDatabase();
+  crashpad::UUID uuid;
+  if (database && ParseUUID(local_id, &uuid)) {
+    database->RequestUpload(uuid);
+  }
+}
+
+class HeliumCrashInfoBarDelegate : public ConfirmInfoBarDelegate {
+ public:
+  explicit HeliumCrashInfoBarDelegate(std::string local_id)
+      : local_id_(std::move(local_id)) {}
+
+  HeliumCrashInfoBarDelegate(const HeliumCrashInfoBarDelegate&) = delete;
+  HeliumCrashInfoBarDelegate& operator=(
+      const HeliumCrashInfoBarDelegate&) = delete;
+
+  ~HeliumCrashInfoBarDelegate() override {
+    OfferedReports().erase(local_id_);
+    if (!resolved_) {
+      DeleteReport(local_id_);
+    }
+  }
+
+ private:
+  infobars::InfoBarDelegate::InfoBarIdentifier GetIdentifier() const override {
+    return DEFAULT_BROWSER_INFOBAR_DELEGATE;
+  }
+
+  const gfx::VectorIcon& GetVectorIcon() const override {
+    return kSadTabIcon;
+  }
+
+  bool EqualsDelegate(infobars::InfoBarDelegate* delegate) const override {
+    return delegate == this;
+  }
+
+  bool ShouldExpire(const NavigationDetails& details) const override {
+    return false;
+  }
+
+  std::u16string GetMessageText() const override {
+    return u"Helium closed unexpectedly. Would you like to send a report?";
+  }
+
+  std::u16string GetMessageTextTemplate() const override {
+    return u"Helium closed unexpectedly. Would you like to send a report? $1";
+  }
+
+  std::vector<MessageSubstitution> GetMessageSubstitutions() const override {
+    return {{u"Always send", true, std::nullopt}};
+  }
+
+  std::u16string GetLinkText() const override {
+    return base::FeatureList::IsEnabled(features::kInfoBarInlineLinks)
+               ? std::u16string()
+               : u"Always send";
+  }
+
+  int GetButtons() const override { return BUTTON_OK; }
+
+  std::u16string GetButtonLabel(InfoBarButton button) const override {
+    return u"Send report";
+  }
+
+  bool Accept() override {
+    resolved_ = true;
+    if (CrashUploadsDisabledByPolicy()) {
+      DeleteReport(local_id_);
+    } else {
+      RequestReportUpload(local_id_);
+    }
+    return true;
+  }
+
+  void InfoBarDismissed() override {
+    resolved_ = true;
+    DeleteReport(local_id_);
+  }
+
+  bool LinkClicked(WindowOpenDisposition disposition) override {
+    return AlwaysSend();
+  }
+
+  bool InlineSubstitutionLinkClicked(
+      size_t index,
+      WindowOpenDisposition disposition) override {
+    if (index != 0) {
+      return false;
+    }
+    return AlwaysSend();
+  }
+
+  bool AlwaysSend() {
+    resolved_ = true;
+    SetHeliumCrashReportingEnabled(true, local_id_);
+    return true;
+  }
+
+  const std::string local_id_;
+  bool resolved_ = false;
+};
+
+}  // namespace
+
+void SetHeliumCrashReportingEnabled(
+    bool enabled,
+    const std::string& approved_local_id) {
+  PrefService* local_state = g_browser_process->local_state();
+  if (!local_state) {
+    return;
+  }
+
+  enabled = enabled && !CrashUploadsDisabledByPolicy();
+
+  crash_reporter::SetUploadConsentFromUser(false);
+  if (enabled) {
+    crashpad::CrashReportDatabase* database = GetDatabase();
+    std::vector<crashpad::CrashReportDatabase::Report> reports;
+    if (database &&
+        database->GetPendingReports(&reports) ==
+            crashpad::CrashReportDatabase::kNoError) {
+      for (const auto& report : reports) {
+        if (!report.upload_explicitly_requested &&
+            report.uuid.ToString() != approved_local_id) {
+          database->DeleteReport(report.uuid);
+        }
+      }
+    }
+    if (!approved_local_id.empty()) {
+      RequestReportUpload(approved_local_id);
+    }
+  }
+
+  local_state->SetBoolean(prefs::kHeliumAlwaysSendCrashReports, enabled);
+  crash_reporter::SetUploadConsentFromUser(enabled);
+}
+
+void MaybeShowHeliumCrashInfoBars(BrowserWindowInterface* browser) {
+  if (!browser || browser->GetType() != BrowserWindowInterface::TYPE_NORMAL ||
+      browser->GetProfile()->IsIncognitoProfile() ||
+      browser->GetProfile()->IsGuestSession()) {
+    return;
+  }
+
+  PrefService* local_state = g_browser_process->local_state();
+  if (!local_state ||
+      local_state->GetBoolean(prefs::kHeliumAlwaysSendCrashReports) ||
+      CrashUploadsDisabledByPolicy()) {
+    return;
+  }
+
+  crashpad::CrashReportDatabase* database = GetDatabase();
+  std::vector<crashpad::CrashReportDatabase::Report> reports;
+  if (!database ||
+      database->GetPendingReports(&reports) !=
+          crashpad::CrashReportDatabase::kNoError) {
+    return;
+  }
+  std::sort(reports.begin(), reports.end(), [](const auto& a, const auto& b) {
+    if (a.creation_time != b.creation_time) {
+      return a.creation_time < b.creation_time;
+    }
+    return a.uuid < b.uuid;
+  });
+
+  auto* web_contents = browser->GetTabStripModel()->GetActiveWebContents();
+  if (!web_contents) {
+    return;
+  }
+  auto* manager =
+      infobars::ContentInfoBarManager::FromWebContents(web_contents);
+  if (!manager) {
+    return;
+  }
+
+  for (const auto& report : reports) {
+    const std::string local_id = report.uuid.ToString();
+    if (report.upload_explicitly_requested ||
+        !OfferedReports().insert(local_id).second) {
+      continue;
+    }
+    manager->AddInfoBar(CreateConfirmInfoBar(
+        std::make_unique<HeliumCrashInfoBarDelegate>(local_id)));
+  }
+}
