+void BrowserView::UpdateZenModeState() {
+  const bool zen_mode_enabled = IsZenModeEnabled();
+  UpdateZenModeEventMonitor();
+  if (zen_mode_border_view_) {
+    zen_mode_border_view_->SetVisible(zen_mode_enabled);
+  }
+
+  if (zen_mode_enabled_ == zen_mode_enabled) {
+    if (zen_mode_enabled_) {
+      UpdateZenModeRevealFromCursor();
+    }
+    return;
+  }
+
+  zen_mode_enabled_ = zen_mode_enabled;
+  if (zen_mode_enabled_) {
+    UpdateZenModeRevealFromCursor();
+  } else {
+    if (!zen_top_chrome_animation_.IsShowing()) {
+      zen_top_chrome_animation_.Show();
+    }
+    if (!zen_side_chrome_animation_.IsShowing()) {
+      zen_side_chrome_animation_.Show();
+    }
+  }
+}
+
+void BrowserView::UpdateZenModeEventMonitor() {
+  if (!GetWidget()) {
+    zen_mode_event_monitor_.reset();
+    return;
+  }
+
+  if (!IsZenModeEnabled()) {
+    zen_mode_event_monitor_.reset();
+    return;
+  }
+
+  if (!zen_mode_event_monitor_) {
+    zen_mode_event_monitor_ = views::EventMonitor::CreateWindowMonitor(
+        this, GetWidget()->GetNativeWindow(),
+        {ui::EventType::kMouseMoved, ui::EventType::kMouseExited});
+  }
+}
+
+void BrowserView::UpdateZenModeRevealFromCursor() {
+  if (!IsZenModeEnabled()) {
+    return;
+  }
+
+  gfx::Point cursor;
+  if (!GetCursorLocationInBrowserView(cursor) ||
+      !GetLocalBounds().Contains(cursor)) {
+    UpdateZenModeReveal(/*reveal_top_chrome=*/false,
+                        /*reveal_side_chrome=*/false);
+    return;
+  }
+
+  const bool reveal_top_chrome =
+      IsPointInZenTopTrigger(cursor) || IsPointInZenTopChromeBounds(cursor);
+  const bool reveal_side_chrome =
+      (IsPointInZenSideTrigger(cursor) || IsPointInZenSideChromeBounds(cursor));
+  UpdateZenModeReveal(reveal_top_chrome, reveal_side_chrome);
+}
+
+void BrowserView::UpdateZenModeReveal(bool reveal_top_chrome,
+                                      bool reveal_side_chrome) {
+  if (!IsZenModeEnabled()) {
+    return;
+  }
+
+  if (!ShouldDrawVerticalTabStrip()) {
+    reveal_side_chrome = false;
+  }
+
+  if (reveal_top_chrome) {
+    if (!zen_top_chrome_animation_.IsShowing()) {
+      zen_top_chrome_animation_.Show();
+    }
+
+    if (toolbar_) {
+      toolbar_->AbortToolbarContainerAnimationsForZenReveal();
+    }
+  } else if (zen_top_chrome_animation_.IsShowing()) {
+    zen_top_chrome_animation_.Hide();
+  }
+
+  if (reveal_side_chrome) {
+    if (!zen_side_chrome_animation_.IsShowing()) {
+      zen_side_chrome_animation_.Show();
+    }
+  } else if (zen_side_chrome_animation_.IsShowing()) {
+    zen_side_chrome_animation_.Hide();
+  }
+}
+
+bool BrowserView::IsZenModeEnabled() const {
+  auto* controller = HeliumLayoutStateController::From(browser_);
+  return controller && controller->IsZenModeEnabled() && GetIsNormalType() &&
+         GetSupportsTabStrip() && !IsFullscreen();
+}
+
+bool BrowserView::IsPointInZenTopTrigger(const gfx::Point& point) const {
+  return point.y() >= 0 && point.y() < kZenModeRevealTriggerThickness;
+}
+
+bool BrowserView::IsPointInZenSideTrigger(const gfx::Point& point) const {
+  if (!ShouldDrawVerticalTabStrip()) {
+    return false;
+  }
+
+  auto* controller = tabs::VerticalTabStripStateController::From(browser_);
+  const bool right_aligned = controller && controller->IsTabStripRightAligned();
+  if (right_aligned) {
+    return point.x() >= width() - kZenModeRevealTriggerThickness;
+  }
+  return point.x() < kZenModeRevealTriggerThickness;
+}
+
+bool BrowserView::IsPointInZenTopChromeBounds(const gfx::Point& point) const {
+  if (!top_container_ || !top_container_->parent()) {
+    return false;
+  }
+  gfx::Rect bounds = views::View::ConvertRectToTarget(
+      top_container_->parent(), this, top_container_->bounds());
+  bounds.Outset(gfx::Outsets::VH(kZenModeTopChromeHoverLeeway,
+                                 kZenModeTopChromeHoverLeeway));
+  return bounds.Contains(point);
+}
+
+bool BrowserView::IsPointInZenSideChromeBounds(const gfx::Point& point) const {
+  if (!vertical_tab_strip_region_view_ ||
+      !vertical_tab_strip_region_view_->parent()) {
+    return false;
+  }
+  gfx::Rect bounds = views::View::ConvertRectToTarget(
+      vertical_tab_strip_region_view_->parent(), this,
+      vertical_tab_strip_region_view_->bounds());
+  bounds.Outset(gfx::Outsets::VH(kZenModeSideChromeHoverLeeway,
+                                 kZenModeSideChromeHoverLeeway));
+  return bounds.Contains(point);
+}
+
+bool BrowserView::GetCursorLocationInBrowserView(
+    gfx::Point& cursor_location) const {
+  if (!zen_mode_event_monitor_) {
+    return false;
+  }
+  cursor_location = zen_mode_event_monitor_->GetLastMouseLocation();
+  views::View::ConvertPointFromScreen(this, &cursor_location);
+  return true;
+}
