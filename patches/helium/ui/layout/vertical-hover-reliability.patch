+void VerticalTabStripStateController::ClearHoverHoldState(bool notify) {
+  hover_expand_timer_.Stop();
+  hover_collapse_timer_.Stop();
+  if (!held_by_hover_) {
+    return;
+  }
+  held_by_hover_ = false;
+  if (notify) {
+    NotifyStateChanged();
+  }
+}
