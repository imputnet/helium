+
+void ToolbarView::MaybeCenterLocationBar() {
+  if (ShouldDisplayToolbarTabStrip() || display_mode_ != DisplayMode::kNormal ||
+      !location_bar_is_centered_.GetValue()) {
+    return;
+  }
+
+  const int toolbar_width = width();
+  const int width_reduction = CenteredLocationBarWidthReduction(toolbar_width);
+  if (width_reduction == 0) {
+    return;
+  }
+
+  gfx::Rect bounds = location_bar_view_->bounds();
+  const int centered_width = std::clamp(
+      bounds.width() - width_reduction,
+      location_bar_view_->GetMinimumSize().width(),
+      kCenteredLocationBarMaxWidth);
+
+  // Keep the location bar centered within the full toolbar when that position
+  // still fits. If surrounding controls push it out, center the location bar
+  // within the available slot instead to avoid a one-sided gap.
+  int centered_x = bounds.x() + (bounds.width() - centered_width) / 2;
+  if (centered_width <= bounds.width()) {
+    const int ideal_centered_x = (toolbar_width - centered_width) / 2;
+    const int min_centered_x = bounds.x();
+    const int max_centered_x = bounds.right() - centered_width;
+    if (ideal_centered_x >= min_centered_x &&
+        ideal_centered_x <= max_centered_x) {
+      centered_x = ideal_centered_x;
+    }
+  }
+
+  bounds.set_x(centered_x);
+  bounds.set_width(centered_width);
+
+  location_bar_view_->SetBoundsRect(bounds);
+}
