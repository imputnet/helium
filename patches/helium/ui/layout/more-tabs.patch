+bool BrowserTabStripController::IsModelIndexForcedHidden(int model_index) const {
+  if (!model_->ContainsIndex(model_index)) {
+    return false;
+  }
+
+  // Grouped tabs stay in the main strip until group-aware overflow is
+  // implemented.
+  if (model_->GetTabGroupForTab(model_index).has_value()) {
+    return false;
+  }
+
+  return overflow_tabs_.contains(model_->GetTabAtIndex(model_index));
+}
