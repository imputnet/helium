+int VerticalTabStripEdgeBorderView::GetOverlayWidth() {
+  return GetRoundedFrameSidebarSeparatorCornerRadius() +
+         views::Separator::kThickness * 2;
+}
+
+void VerticalTabStripEdgeBorderView::OnPaint(gfx::Canvas* canvas) {
+  const bool zen_mode = browser_view_->IsZenModeEnabledForLayout();
+  const auto* vertical_tab_strip_region =
+      browser_view_->vertical_tab_strip_region_view_for_testing();
+  const bool hover_expanded_overlay =
+      !zen_mode && state_controller_->IsCollapsed() &&
+      vertical_tab_strip_region &&
+      !vertical_tab_strip_region->IsVisuallyCollapsed();
+  if (!zen_mode && !hover_expanded_overlay) {
+    return;
+  }
+
+  const bool rounded_frame =
+      browser_view_->browser()->profile()->GetPrefs()->GetBoolean(
+          prefs::kHeliumRoundedFrame);
+  if (zen_mode && browser_view_->IsZenModeSideChromePinned()) {
+    return;
+  }
+
+  const int thickness = views::Separator::kThickness;
+  const int bottom_inset = rounded_frame
+                               ? GetRoundedFrameSidebarSeparatorBottomInset()
+                               : 0;
+  const bool top_bar_hidden =
+      zen_mode && browser_view_->GetTopChromeRevealRatio() <= 0.0f;
+  const int top_inset = rounded_frame && top_bar_hidden
+                            ? GetRoundedFrameSidebarSeparatorBottomInset()
+                            : 0;
+  const int line_height = std::max(0, height() - top_inset - bottom_inset);
+  if (line_height <= 0) {
+    return;
+  }
+
+  const bool right_aligned = state_controller_->IsTabStripRightAligned();
+  const float half_thickness = thickness / 2.0f;
+  const float x = right_aligned ? width() - half_thickness : half_thickness;
+
+  SkPathBuilder path_builder;
+  const bool use_rounded_edge = rounded_frame || hover_expanded_overlay;
+  if (use_rounded_edge) {
+    const float start_y = top_inset + half_thickness;
+    const float end_y = top_inset + line_height - half_thickness;
+    const float curve_radius = std::min<float>(
+        GetRoundedFrameSidebarSeparatorCornerRadius(),
+        std::max(0.0f, (end_y - start_y) / 2.0f));
+    const float content_sign = right_aligned ? -1.0f : 1.0f;
+    const bool round_top = zen_mode || hover_expanded_overlay || top_inset > 0;
+    const bool round_bottom = bottom_inset > 0;
+
+    // The rounded content outline is still present behind this overlay. Mask
+    // its top/bottom horizontal stroke inside the overlay strip before drawing
+    // our replacement curve, otherwise it reads as a straight segment extending
+    // too far under the sidebar.
+    cc::PaintFlags mask_flags;
+    mask_flags.setColor(
+        GetColorProvider()->GetColor(kColorWebContentsBackground));
+    mask_flags.setStyle(cc::PaintFlags::kFill_Style);
+    const float endpoint_radius = curve_radius;
+    // Leave a small subpixel overlap with the existing content outline so AA
+    // at the curve endpoint does not create a visible hairline gap.
+    const float mask_width =
+        std::max(0.0f, x + endpoint_radius - thickness);
+    const float mask_x = right_aligned ? width() - mask_width : 0.0f;
+    canvas->DrawRect(
+        gfx::RectF(mask_x, top_inset, mask_width, thickness + 1),
+        mask_flags);
+    if (round_bottom) {
+      canvas->DrawRect(gfx::RectF(mask_x, end_y - half_thickness, mask_width,
+                                  thickness + 1),
+                       mask_flags);
+    }
+    if (round_top) {
+      path_builder.moveTo(x + content_sign * endpoint_radius, start_y);
+      path_builder.quadTo(x, start_y, x, start_y + curve_radius);
+    } else {
+      path_builder.moveTo(x, start_y);
+    }
+
+    path_builder.lineTo(x, end_y - (round_bottom ? curve_radius : 0.0f));
+    if (round_bottom) {
+      path_builder.quadTo(x, end_y,
+                          x + content_sign * endpoint_radius, end_y);
+    }
+  } else {
+    path_builder.moveTo(x, top_inset);
+    path_builder.lineTo(x, top_inset + line_height);
+  }
+
+  cc::PaintFlags flags;
+  flags.setStrokeWidth(thickness);
+  flags.setColor(
+      GetColorProvider()->GetColor(kColorToolbarContentAreaSeparator));
+  flags.setStyle(cc::PaintFlags::kStroke_Style);
+  flags.setAntiAlias(use_rounded_edge);
+  canvas->DrawPath(path_builder.detach(), flags);
+}
