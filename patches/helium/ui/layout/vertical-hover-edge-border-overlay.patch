+// Overlay strip that paints the vertical tab strip's content-edge border in a
+// small transparent region outside the tab strip bounds.  This gives rounded
+// border ends room to paint without affecting tab strip/content layout.
+class VerticalTabStripEdgeBorderView final : public views::View {
+  METADATA_HEADER(VerticalTabStripEdgeBorderView, views::View)
+
+ public:
+  VerticalTabStripEdgeBorderView(
+      BrowserView* browser_view,
+      tabs::VerticalTabStripStateController* state_controller);
+  VerticalTabStripEdgeBorderView(const VerticalTabStripEdgeBorderView&) =
+      delete;
+  VerticalTabStripEdgeBorderView& operator=(
+      const VerticalTabStripEdgeBorderView&) = delete;
+  ~VerticalTabStripEdgeBorderView() override;
+
+  static int GetOverlayWidth();
+
+  // views::View:
+  void OnPaint(gfx::Canvas* canvas) override;
+
+ private:
+  raw_ptr<BrowserView> browser_view_ = nullptr;
+  raw_ptr<tabs::VerticalTabStripStateController> state_controller_ = nullptr;
+  base::CallbackListSubscription collapsed_state_changed_subscription_;
+};
