+
+#ifndef CHROME_BROWSER_UI_WEBUI_SETTINGS_HELIUM_CRASH_REPORTING_HANDLER_H_
+#define CHROME_BROWSER_UI_WEBUI_SETTINGS_HELIUM_CRASH_REPORTING_HANDLER_H_
+
+#include <memory>
+
+#include "chrome/browser/ui/webui/settings/settings_page_ui_handler.h"
+#include "components/prefs/pref_member.h"
+
+namespace settings {
+
+class HeliumCrashReportingHandler : public SettingsPageUIHandler {
+ public:
+  HeliumCrashReportingHandler();
+  HeliumCrashReportingHandler(const HeliumCrashReportingHandler&) = delete;
+  HeliumCrashReportingHandler& operator=(const HeliumCrashReportingHandler&) =
+      delete;
+  ~HeliumCrashReportingHandler() override;
+
+  void RegisterMessages() override;
+  void OnJavascriptAllowed() override;
+  void OnJavascriptDisallowed() override;
+
+ private:
+  base::DictValue CreateState() const;
+  void HandleGetState(const base::ListValue& args);
+  void HandleSetMode(const base::ListValue& args);
+  void OnPrefChanged();
+
+  std::unique_ptr<IntegerPrefMember> pref_member_;
+  std::unique_ptr<BooleanPrefMember> policy_pref_member_;
+};
+
+}  // namespace settings
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SETTINGS_HELIUM_CRASH_REPORTING_HANDLER_H_
