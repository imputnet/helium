+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/settings/helium_crash_reporting_handler.h"
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/ui/startup/helium_crash_infobar_delegate.h"
+#include "chrome/common/pref_names.h"
+#include "components/crash/core/app/crashpad.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/web_ui.h"
+
+namespace settings {
+
+HeliumCrashReportingHandler::HeliumCrashReportingHandler() = default;
+HeliumCrashReportingHandler::~HeliumCrashReportingHandler() = default;
+
+void HeliumCrashReportingHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getHeliumCrashReporting",
+      base::BindRepeating(&HeliumCrashReportingHandler::HandleGetState,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "setHeliumCrashReportingEnabled",
+      base::BindRepeating(&HeliumCrashReportingHandler::HandleSetEnabled,
+                          base::Unretained(this)));
+}
+
+void HeliumCrashReportingHandler::OnJavascriptAllowed() {
+  pref_member_ = std::make_unique<BooleanPrefMember>();
+  pref_member_->Init(
+      prefs::kHeliumAlwaysSendCrashReports, g_browser_process->local_state(),
+      base::BindRepeating(&HeliumCrashReportingHandler::OnPrefChanged,
+                          base::Unretained(this)));
+}
+
+void HeliumCrashReportingHandler::OnJavascriptDisallowed() {
+  pref_member_.reset();
+}
+
+base::DictValue HeliumCrashReportingHandler::CreateState() {
+  const bool disabled_by_policy = crash_reporter::UploadsDisabledByPolicy();
+
+  base::DictValue state;
+  state.Set("enabled",
+            !disabled_by_policy &&
+                g_browser_process->local_state()->GetBoolean(
+                    prefs::kHeliumAlwaysSendCrashReports));
+  state.Set("managed", disabled_by_policy);
+  return state;
+}
+
+void HeliumCrashReportingHandler::HandleGetState(
+    const base::ListValue& args) {
+  AllowJavascript();
+  CHECK_GT(args.size(), 0u);
+  ResolveJavascriptCallback(args[0], CreateState());
+}
+
+void HeliumCrashReportingHandler::HandleSetEnabled(
+    const base::ListValue& args) {
+  CHECK_GT(args.size(), 0u);
+  const bool disabled_by_policy = crash_reporter::UploadsDisabledByPolicy();
+  SetHeliumCrashReportingEnabled(!disabled_by_policy && args[0].GetBool());
+}
+
+void HeliumCrashReportingHandler::OnPrefChanged(
+    const std::string& pref_name) {
+  DCHECK_EQ(prefs::kHeliumAlwaysSendCrashReports, pref_name);
+  FireWebUIListener("helium-crash-reporting-change", CreateState());
+}
+
+}  // namespace settings
