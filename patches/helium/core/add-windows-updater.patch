@@ -58,6 +58,111 @@
 
 }  // namespace
 
+#if BUILDFLAG(IS_WIN)
+#include "base/json/json_reader.h"
+#include "chrome/browser/lifetime/application_lifetime.h"
+
+class HeliumVersionUpdaterWin : public VersionUpdater {
+ public:
+  explicit HeliumVersionUpdaterWin(content::WebContents* web_contents)
+      : web_contents_(web_contents) {}
+
+  void CheckForUpdates(StatusCallback callback, PromoteCallback promote_callback) override {
+    callback_ = std::move(callback);
+
+    auto* profile = Profile::FromBrowserContext(web_contents_->GetBrowserContext());
+    GURL url = helium::GetBrowserUpdateURL(*profile->GetPrefs());
+
+    if (url.is_empty() || url.spec().find("dummy") != std::string::npos) {
+      std::move(callback_).Run(Status::kDisabledByAdmin, 0, false, false, "", 0, u"");
+      return;
+    }
+
+    auto req = std::make_unique<network::ResourceRequest>();
+    req->url = url;
+    req->credentials_mode = network::mojom::CredentialsMode::kOmit;
+    req->headers.SetHeader("User-Agent", "Helium-Browser");
+
+    loader_ = network::SimpleURLLoader::Create(std::move(req), MISSING_TRAFFIC_ANNOTATION);
+    loader_->DownloadToStringOfUnboundedSizeUntilCrashAndDie(
+        profile->GetURLLoaderFactory().get(),
+        base::BindOnce(&HeliumVersionUpdaterWin::OnUpdateCheckDone, base::Unretained(this)));
+
+    std::move(callback_).Run(Status::kChecking, 0, false, false, "", 0, u"");
+  }
+
+  void RelaunchBrowser() override {
+    chrome::AttemptRestart();
+  }
+
+ private:
+  void OnUpdateCheckDone(std::unique_ptr<std::string> body) {
+    if (!body || body->empty()) {
+      std::move(callback_).Run(Status::kUpdateError, 0, false, false, "", 0, u"");
+      return;
+    }
+
+    auto root = base::JSONReader::Read(*body);
+    if (!root || !root->is_dict()) {
+      std::move(callback_).Run(Status::kUpdateError, 0, false, false, "", 0, u"");
+      return;
+    }
+
+    const std::string* tag = root->GetDict().FindString("tag_name");
+    if (!tag) {
+      std::move(callback_).Run(Status::kUpdateError, 0, false, false, "", 0, u"");
+      return;
+    }
+
+    std::string v = *tag;
+    if (v[0] == 'v') v = v.substr(1);
+
+    if (base::Version(v) > base::Version(version_info::GetHeliumVersionNumber())) {
+      std::move(callback_).Run(Status::kNearlyUpdated, 0, false, false, "", 0, u"");
+    } else {
+      std::move(callback_).Run(Status::kUpToDate, 0, false, false, "", 0, u"");
+    }
+  }
+
+  raw_ptr<content::WebContents> web_contents_;
+  StatusCallback callback_;
+  std::unique_ptr<network::SimpleURLLoader> loader_;
+};
+#endif
+
+std::unique_ptr<VersionUpdater> VersionUpdater::Create(
+    content::WebContents* web_contents) {
+#if BUILDFLAG(IS_CHROMEOS_ASH)
+  return std::make_unique<VersionUpdaterChromeOS>(web_contents);
+#elif BUILDFLAG(IS_MAC)
+  return std::make_unique<VersionUpdaterMac>(web_contents);
+#elif BUILDFLAG(IS_WIN)
+  return std::make_unique<HeliumVersionUpdaterWin>(web_contents);
+#else
+  return std::make_unique<VersionUpdaterBasic>(web_contents);
+#endif
+}
