+#ifndef COMPONENTS_NESTED_TABS_NESTED_TAB_VISUAL_DATA_H_
+#define COMPONENTS_NESTED_TABS_NESTED_TAB_VISUAL_DATA_H_
+
+namespace tabs {
+    class NestedTabCollection;
+}
+
+namespace nested_tabs {
+
+// Represents the visual state of a nested tab, including its layout type and the
+// proportional size of the webcontents. Also used for persistence
+class NestedTabVisualData {
+ public:
+  NestedTabVisualData() = default;
+  explicit NestedTabVisualData(bool is_collapsed) : is_collapsed_(is_collapsed) {}
+  ~NestedTabVisualData() = default;
+
+  NestedTabVisualData(const NestedTabVisualData& other) = default;
+  NestedTabVisualData(NestedTabVisualData&& other) = default;
+
+  NestedTabVisualData& operator=(const NestedTabVisualData& other) = default;
+  NestedTabVisualData& operator=(NestedTabVisualData&& other) = default;
+
+
+  // Checks whether two instances are visually equivalent.
+  friend bool operator==(const NestedTabVisualData&,
+                         const NestedTabVisualData&) = default;
+
+  bool IsCollapsed() const { return is_collapsed_; }
+  void SetIsCollapsed(bool is_collapsed) {
+    is_collapsed_ = is_collapsed;
+  }
+ private:
+
+
+
+ bool is_collapsed_ = false;
+};
+
+}  // namespace nested_tabs
