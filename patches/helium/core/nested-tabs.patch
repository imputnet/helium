+
+gfx::Range NestedTabData::GetIndexRange() const {
+  std::vector<tabs::TabInterface*> nested_tabs = ListTabs();
+
+  if (nested_tabs.empty()) {
+    return gfx::Range();
+  }
+
+  // Find the TabStripCollection (for which indexes are based off of.)
+  tabs::TabCollection* root_collection = collection_;
+  while (root_collection &&
+         root_collection->type() != tabs::TabCollection::Type::TABSTRIP) {
+    root_collection = root_collection->GetParentCollection();
+  }
+
+  if (!root_collection) {
+    return gfx::Range();
+  }
+
+  int start_index =
+      root_collection->GetIndexOfTabRecursive(nested_tabs[0]).value();
+  return gfx::Range(start_index, start_index + nested_tabs.size());
+}
