+void TabStripModel::NotifyNestedDetached(
+    tabs::NestedTabCollection* nested_collection) {
+  // Build orphaned_children = all non-owner tabs in DFS order so listeners
+  // see the full set that left the tabstrip.
+  const tabs::TabHandle owner_handle =
+      nested_collection->data()->owner_tab();
+  std::vector<tabs::TabHandle> orphaned_children;
+  for (tabs::TabInterface* tab : nested_collection->GetTabsRecursive()) {
+    if (tab->GetHandle() == owner_handle) {
+      continue;
+    }
+    orphaned_children.push_back(tab->GetHandle());
+  }
+
+  NestedTabChange change(this, nested_collection->GetNestedTabId(),
+                         NestedTabChange::DestroyedChange(
+                             owner_handle, std::move(orphaned_children)));
+  for (auto& observer : observers_) {
+    observer.OnNestedTabChanged(change);
+  }
+}
+
+void TabStripModel::NotifyNestedAttached(
+    tabs::NestedTabCollection* nested_collection) {
+  const tabs::TabHandle owner_handle =
+      nested_collection->data()->owner_tab();
+  std::vector<tabs::TabHandle> initial_children;
+  for (tabs::TabInterface* tab : nested_collection->GetTabsRecursive()) {
+    if (tab->GetHandle() == owner_handle) {
+      continue;
+    }
+    initial_children.push_back(tab->GetHandle());
+  }
+
+  NestedTabChange change(this, nested_collection->GetNestedTabId(),
+                         NestedTabChange::CreatedChange(
+                             owner_handle, std::move(initial_children),
+                             *nested_collection->data()->visual_data()));
+  for (auto& observer : observers_) {
+    observer.OnNestedTabChanged(change);
+  }
+}
