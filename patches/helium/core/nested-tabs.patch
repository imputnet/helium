+void VerticalTabStripController::SetSubtreeCollapsed(
+    const nested_tabs::NestedTabId& nested_id,
+    bool collapsed) {
+  const nested_tabs::NestedTabData* data = model_->GetNestingData(nested_id);
+
+  bool is_currently_collapsed = model_->IsSubtreeCollapsed(nested_id);
+
+  if (is_currently_collapsed == collapsed) {
+    return;
+  }
+
+  tabs::TabInterface* active_tab = model_->GetActiveTab();
+  if (active_tab && collapsed) {
+    if (data->GetIndexRange().Contains(
+            gfx::Range(model_->GetIndexOfTab(active_tab)))) {
+      // Active tab will be collapsed. Select the parent of the collapsing
+      // NESTED.
+      SelectTab(data->owner_tab().Get(),
+                TabStripUserGestureDetails(
+                    TabStripUserGestureDetails::GestureType::kOther));
+    }
+  }
+
+  model_->SetSubtreeCollapsed(nested_id, collapsed);
+}
