+const TabCollectionNode* VerticalNestedTabView::GetCollectionNodeFromView(
+    const views::View& view) const {
+  if (auto* tab_view = views::AsViewClass<VerticalTabView>(&view)) {
+    return tab_view->collection_node();
+  } else if (auto* split_tab_view =
+                 views::AsViewClass<VerticalSplitTabView>(&view)) {
+    return split_tab_view->collection_node();
+  } else if (auto* nested_tab_view =
+                 views::AsViewClass<VerticalNestedTabView>(&view)) {
+    return nested_tab_view->collection_node();
+  }
+  return nullptr;
