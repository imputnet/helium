+std::optional<nested_tabs::NestedTabId> TabStripModel::Nest(
+    std::optional<int> parent,
+    std::vector<int> children,
+    std::optional<nested_tabs::NestedTabVisualData> visual_data,
+    std::optional<size_t> target_child_idx) {
+  ReentrancyCheck reentrancy_check(&reentrancy_guard_);
+  auto result = NestImpl(parent, children, visual_data, target_child_idx);
+  // Flush pending TabCollectionObserver notifications queued by
+  // FindOrCreateNestedFor / MoveTabToNested. Without this they would only
+  // dispatch on the next mutation, leaving the view tree one event behind.
+  CompleteModelUpdateTransaction();
+  return result;
+}
+
+void TabStripModel::RestoreNested(
+    const nested_tabs::NestedTabId& nested_id,
+    tabs::TabInterface* owner,
+    const std::vector<tabs::TabInterface*>& children,
+    const nested_tabs::NestedTabVisualData& visual_data) {
+  ReentrancyCheck reentrancy_check(&reentrancy_guard_);
+  int owner_idx = GetIndexOfTab(owner);
+  auto children_idxs =
+      children |
+      std::views::transform([&](auto tab) { return GetIndexOfTab(tab); }) |
+      std::ranges::to<std::vector<int>>();
+  if (std::ranges::is_sorted(children_idxs) &&
+      (children.empty() || owner_idx < children_idxs.front())) {
+    std::ignore =
+        NestImpl(owner_idx, children_idxs, visual_data, {}, nested_id);
+  } else {
+      LOG(ERROR) << "Nested precondition failed on restore, falling through";
+  }
+
+  CompleteModelUpdateTransaction();
+}
+
+std::optional<nested_tabs::NestedTabId> TabStripModel::NestImpl(
+    std::optional<int> parent,
+    std::vector<int> children,
+    std::optional<nested_tabs::NestedTabVisualData> visual_data,
+    std::optional<size_t> target_child_idx,
+    std::optional<nested_tabs::NestedTabId> id_override) {
+  if (children.empty()) {
+    return std::nullopt;
+  }
+  tabs::TabInterface* parent_tab = parent ? GetTabAtIndex(*parent) : nullptr;
+  CHECK(!parent || parent_tab) << "Unable to find parent tab at index!";
+  CHECK(!parent_tab->IsPinned()) << "Pinned tabs cannot participate in NESTED!";
+
+  // Need to filter tabs from the same SPLIT
+  std::set<split_tabs::SplitTabId> seen_splits = {};
+  std::vector<tabs::TabInterface*> children_tabs =
+      children | std::views::transform([&](auto idx) {
+        return this->GetTabAtIndex(idx);
+      }) |
+      std::views::filter([&](auto tab) {
+        if (!tab) {
+          return false;
+        }
+
+        auto split = tab->GetSplit();
+        if (split) {
+          if (seen_splits.contains(*split)) {
+            return false;
+          }
+          seen_splits.insert(*split);
+        }
+
+        return true;
+      }) |
+      std::ranges::to<std::vector>();
+
+  // Check for possible cycles
+  // A cycle is defined as the parent being within any child's tree
+  CHECK(!parent ||
+        !IsDescendantOfAny(*parent, std::set(children.begin(), children.end())))
+      << "Cycle detected while trying to nest tabs.";
+
+  // No cycles detected, proceed with nest.
+
+  // Snapshot per source: id, owner (in case destroyed), and removed tabs.
+  struct SourceSnapshot {
+    nested_tabs::NestedTabId id;
+    tabs::TabHandle owner;
+    std::vector<tabs::TabHandle> removed_children;
+  };
+  base::flat_map<nested_tabs::NestedTabId, SourceSnapshot> sources;
+
+  for (auto* child : children_tabs) {
+    auto* p = child->GetParentCollection();
+    if (p && p->type() == tabs::TabCollection::Type::SPLIT) {
+      p = p->GetParentCollection();
+    }
+    if (p && p->type() == tabs::TabCollection::Type::NESTED) {
+      auto* nested = static_cast<const tabs::NestedTabCollection*>(p);
+      auto& snap = sources
+                       .try_emplace(nested->data()->id(),
+                                    SourceSnapshot{nested->data()->id(),
+                                                   nested->data()->owner_tab(),
+                                                   {}})
+                       .first->second;
+      snap.removed_children.push_back(child->GetHandle());
+    }
+  }
+
+  //  Do the moves.
+  std::optional<nested_tabs::NestedTabId> retval;
+  if (parent_tab) {
+    const auto [parent_nested, did_create] =
+        contents_data_->FindOrCreateNestedFor(parent_tab, visual_data,
+                                              id_override);
+
+    // Remove the destination from the sources map AFTER it's known (now that
+    // parent_nested is in scope), there's no net change for tabs already
+    // there.
+    sources.erase(parent_nested->data()->id());
+
+    // |target_child_idx| is the position among the parent's non-owner
+    // children (matches GetChildIndices() semantics). The owner occupies
+    // the NESTED collection's children[0], so shift by 1 when computing the
+    // collection-level insertion index.
+    size_t offset = 0;
+    for (auto* child : children_tabs) {
+      contents_data_->MoveTabToNested(
+          child, parent_nested->data()->id(),
+          target_child_idx.transform([&](auto i) { return i + offset + 1; }));
+      if (target_child_idx) {
+        offset++;
+      }
+      // ignore the returned NestedDestruction, handled in the dispatch loop
+    }
+
+    auto child_handles =
+        children_tabs |
+        std::views::transform([](auto t) { return t->GetHandle(); }) |
+        std::ranges::to<std::vector>();
+
+    if (did_create) {
+      observers_.Notify(
+          &TabStripModelObserver::OnNestedTabChanged,
+          NestedTabChange(this, parent_nested->data()->id(),
+                          NestedTabChange::CreatedChange(
+                              parent_tab->GetHandle(), std::move(child_handles),
+                              visual_data.value_or({}))));
+    } else {
+      observers_.Notify(&TabStripModelObserver::OnNestedTabChanged,
+                        NestedTabChange(this, parent_nested->data()->id(),
+                                        NestedTabChange::ContentsChange(
+                                            std::move(child_handles), {})));
+    }
+
+    retval = parent_nested->data()->id();
+  } else {
+    for (auto* child : children_tabs) {
+      contents_data_->MoveTabToTopLevel(child);
+    }
+    retval = std::nullopt;
+  }
+
+  // Single dispatch loop for every snapshot source.
+  for (auto& [id, snap] : sources) {
+    if (contents_data_->GetNestedTabCollection(id)) {
+      // Source still alive: contents changed.
+      observers_.Notify(
+          &TabStripModelObserver::OnNestedTabChanged,
+          NestedTabChange(this, id,
+                          NestedTabChange::ContentsChange(
+                              {}, std::move(snap.removed_children))));
+    } else {
+      // Source destroyed during moves.
+      observers_.Notify(
+          &TabStripModelObserver::OnNestedTabChanged,
+          NestedTabChange(this, id,
+                          NestedTabChange::DestroyedChange(
+                              snap.owner, std::move(snap.removed_children))));
+    }
+  }
+
+  return retval;
+}
