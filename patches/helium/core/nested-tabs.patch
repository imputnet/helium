+views::ScrollView* VerticalNestedTabView::GetScrollViewForContainer() const {
+  // GetScrollViewForContents inspects pointers only; const-incorrect API
+  views::View* ancestor =
+      const_cast<views::View*>(static_cast<const views::View*>(this));
+  while (ancestor) {
+    if (auto* scroll_view =
+            views::ScrollView::GetScrollViewForContents(ancestor)) {
+      return scroll_view;
+    }
+    ancestor = ancestor->parent();
+  }
+  return nullptr;
