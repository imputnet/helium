+
+std::optional<nested_tabs::NestedTabId> TabStripModel::GetEnclosingNestedId(
+    int index) const {
+  tabs::TabInterface* tab = GetTabAtIndex(index);
+  if (!tab) {
+    return {};
+  }
+
+  // Deepest NESTED containing `tab` as a non-owner child. Self-owning
+  // NESTEDs are skipped, see GetInnermostNestedId for the inclusive walk.
+  for (const tabs::TabCollection* c = tab->GetParentCollection(); c;
+       c = c->GetParentCollection()) {
+    if (c->type() != tabs::TabCollection::Type::NESTED) {
+      continue;
+    }
+    const auto* nested = static_cast<const tabs::NestedTabCollection*>(c);
+    if (nested->data()->owner_tab().Get() == tab) {
+      continue;
+    }
+    return nested->GetNestedTabId();
+  }
+  return {};
+}
+
+std::optional<nested_tabs::NestedTabId> TabStripModel::GetInnermostNestedId(
+    int index) const {
+  tabs::TabInterface* tab = GetTabAtIndex(index);
+  if (!tab) {
+    return {};
+  }
+
+  for (const tabs::TabCollection* c = tab->GetParentCollection(); c;
+       c = c->GetParentCollection()) {
+    if (c->type() == tabs::TabCollection::Type::NESTED) {
+      return static_cast<const tabs::NestedTabCollection*>(c)->GetNestedTabId();
+    }
+  }
+  return {};
+}
+
+std::optional<nested_tabs::NestedTabId> TabStripModel::GetOwnedNestedId(
+    const tabs::TabInterface* tab) const {
+  tabs::NestedTabCollection* maybe_ntc =
+      contents_data_->GetNestedTabCollection(tab);
+  if (maybe_ntc) {
+    return maybe_ntc->GetNestedTabId();
+  }
+  return std::nullopt;
+}
+
+bool TabStripModel::AllCanNestInto(const std::set<int>& subject_idxs,
+                                   int target_idx) const {
+  if (subject_idxs.empty()) {
+    return false;
+  }
+  tabs::TabInterface* target_tab = GetTabAtIndex(target_idx);
+  if (!target_tab || target_tab->IsPinned() || target_tab->IsSplit()) {
+    return false;
+  }
+  if (std::ranges::any_of(subject_idxs, [&](auto subject_idx) {
+        tabs::TabInterface* subject_tab = GetTabAtIndex(subject_idx);
+        if (!subject_tab) {
+          // Invalid tab -> bail
+          return true;
+        }
+        return subject_tab->IsPinned();
+      })) {
+    return false;
+  }
+  if (IsDescendantOfAny(target_idx, subject_idxs)) {
+    return false;
+  }
+
+  return true;
+}
+
+void TabStripModel::MoveNestedTo(
+    const nested_tabs::NestedTabId& nested_id,
+    int to_index,
+    std::optional<tab_groups::TabGroupId> target_group) {
+  ReentrancyCheck reentrancy_check(&reentrancy_guard_);
+  MoveNestedToImpl(nested_id, to_index, target_group);
+}
+
+void TabStripModel::MoveNestedToImpl(
+    const nested_tabs::NestedTabId& nested_id,
+    int to_index,
+    std::optional<tab_groups::TabGroupId> target_group) {
+  auto* ntc = contents_data_->GetNestedTabCollection(nested_id);
+  CHECK(ntc);
+  const int old_index = GetIndexOfTab(ntc->data()->owner_tab().Get());
+  // Owner lives inside its NESTED as children[0], so GetTabsRecursive()
+  // already includes it and returns sorted recursive-index order.
+  std::vector<int> tab_indices = ntc->GetTabsRecursive() |
+                                 std::views::transform([&](const auto& tab) {
+                                   return GetIndexOfTab(tab);
+                                 }) |
+                                 std::ranges::to<std::vector<int>>();
+
+  const int sz_moving = static_cast<int>(tab_indices.size());
+  // Drag-handler callers subtract `tab_drag_data_`'s size from a pre-removal
+  // target, but for NESTED drags `tab_drag_data_` holds only the owner slot.
+  // Clamp so the FindMovePositionRecursive walk can actually match the
+  // destination instead of overshooting and returning nullopt.
+  to_index = std::clamp(to_index, 0, count() - sz_moving);
+
+  // Self-overlap is a no-op: moving the NESTED into its own range doesn't
+  // change anything, and `FindMovePositionRecursive` can't resolve a target
+  // that's currently occupied by the moving collection itself.
+  if (to_index >= old_index && to_index < old_index + sz_moving) {
+    return;
+  }
+
+  // Cycle guard: dest must not be inside the moving NESTED's subtree.
+  if (IsDescendantOfAny(to_index, {old_index})) {
+    return;
+  }
+
+  // Walk out of any enclosing NESTED that is the moving NESTED itself, owns
+  // the destination slot (would displace children[0]), conflicts with a
+  // caller-specified target group, or doesn't actually contain the
+  // post-removal destination. `to_index_pre` shifts past the contiguous
+  // moving range so it can index the pre-removal model.
+  int to_index_pre = to_index;
+  if (to_index_pre >= old_index) {
+    to_index_pre += sz_moving;
+  }
+  std::optional<nested_tabs::NestedTabId> enclosing =
+      (to_index_pre >= 0 && to_index_pre < count())
+          ? GetInnermostNestedId(to_index_pre)
+          : std::nullopt;
+  while (enclosing) {
+    auto* enc_ntc = contents_data_->GetNestedTabCollection(*enclosing);
+    if (!enc_ntc) {
+      enclosing = std::nullopt;
+      break;
+    }
+    bool inside_moving = false;
+    for (const tabs::TabCollection* c = enc_ntc; c;
+         c = c->GetParentCollection()) {
+      if (c == static_cast<tabs::TabCollection*>(ntc)) {
+        inside_moving = true;
+        break;
+      }
+    }
+    // Boundary: landing exactly on the enclosing owner's slot would force
+    // the moved NESTED into children[0]'s position, breaking the invariant.
+    const bool boundary =
+        !inside_moving &&
+        to_index_pre == GetIndexOfTab(enc_ntc->data()->owner_tab().Get());
+    // If caller specified a target group, the enclosing NESTED must lie
+    // inside it; otherwise dst_collection would resolve to a NESTED that
+    // overrides target_group.
+    bool outside_target_group = false;
+    if (target_group.has_value()) {
+      outside_target_group = true;
+      for (const tabs::TabCollection* c = enc_ntc; c;
+           c = c->GetParentCollection()) {
+        if (c->type() != tabs::TabCollection::Type::GROUP) {
+          continue;
+        }
+        const auto* group_coll =
+            static_cast<const tabs::TabGroupTabCollection*>(c);
+        if (group_coll->GetTabGroup() &&
+            group_coll->GetTabGroup()->id() == *target_group) {
+          outside_target_group = false;
+          break;
+        }
+      }
+    }
+    // Dest must land inside enclosing's post-removal range, else the walk
+    // overshoots `destination_index` while still in enclosing's subtree.
+    gfx::Range enc_pre_range = enc_ntc->data()->GetIndexRange();
+    int sz_before_enc = 0;
+    int sz_inside_enc = 0;
+    for (int idx : tab_indices) {
+      if (idx < static_cast<int>(enc_pre_range.GetMin())) {
+        ++sz_before_enc;
+      } else if (idx < static_cast<int>(enc_pre_range.GetMax())) {
+        ++sz_inside_enc;
+      }
+    }
+    const int enc_post_start =
+        static_cast<int>(enc_pre_range.GetMin()) - sz_before_enc;
+    const int enc_post_end = static_cast<int>(enc_pre_range.GetMax()) -
+                             sz_before_enc - sz_inside_enc;
+    const bool dest_outside_enc =
+        (to_index < enc_post_start || to_index >= enc_post_end);
+    if (!inside_moving && !boundary && !outside_target_group &&
+        !dest_outside_enc) {
+      break;  // safe enclosing
+    }
+    tabs::TabCollection* parent = enc_ntc->GetParentCollection();
+    if (!parent || parent->type() != tabs::TabCollection::Type::NESTED) {
+      // Walking out into a GROUP means the move should land inside that
+      // group as a sibling of the enclosing NESTED; propagate it so dst
+      // picks the group instead of falling back to unpinned.
+      if (parent && parent->type() == tabs::TabCollection::Type::GROUP) {
+        const auto* gc =
+            static_cast<const tabs::TabGroupTabCollection*>(parent);
+        if (gc->GetTabGroup() && !target_group.has_value()) {
+          target_group = gc->GetTabGroup()->id();
+        }
+      }
+      enclosing = std::nullopt;
+      break;
+    }
+    enclosing =
+        static_cast<tabs::NestedTabCollection*>(parent)->GetNestedTabId();
+  }
+
+  // Promote target_group if the destination tab lives inside a GROUP and
+  // none was explicitly chosen; otherwise dst falls back to unpinned and
+  // the walk overshoots while still inside the group.
+  if (!enclosing.has_value() && !target_group.has_value() &&
+      to_index_pre >= 0 && to_index_pre < count()) {
+    tabs::TabInterface* dest_tab = GetTabAtIndex(to_index_pre);
+    for (const tabs::TabCollection* c =
+             dest_tab ? dest_tab->GetParentCollection() : nullptr;
+         c; c = c->GetParentCollection()) {
+      if (c->type() != tabs::TabCollection::Type::GROUP) {
+        continue;
+      }
+      const auto* gc = static_cast<const tabs::TabGroupTabCollection*>(c);
+      if (gc->GetTabGroup()) {
+        target_group = gc->GetTabGroup()->id();
+      }
+      break;
+    }
+  }
+
+  static constexpr tabs::TabCollection::TypeEnumSet kRetainCollectionTypes = {
+      tabs::TabCollection::Type::SPLIT, tabs::TabCollection::Type::NESTED};
+
+  // Clamp `to_index` against whatever dst_collection resolves to (enclosing
+  // NESTED or target group), so the walk can match inside dst instead of
+  // overshooting.
+  if (enclosing.has_value()) {
+    const auto* enc_coll = contents_data_->GetNestedTabCollection(*enclosing);
+    if (enc_coll) {
+      gfx::Range enc_pre = enc_coll->data()->GetIndexRange();
+      int sz_inside = 0;
+      for (int idx : tab_indices) {
+        if (idx >= static_cast<int>(enc_pre.GetMin()) &&
+            idx < static_cast<int>(enc_pre.GetMax())) {
+          ++sz_inside;
+        }
+      }
+      const int min_dest = static_cast<int>(enc_pre.GetMin()) + 1;
+      const int max_dest = static_cast<int>(enc_pre.GetMax()) - sz_inside;
+      if (max_dest >= min_dest) {
+        to_index = std::clamp(to_index, min_dest, max_dest);
+      }
+    }
+  } else if (target_group.has_value()) {
+    const tabs::TabGroupTabCollection* group_coll =
+        contents_data_->GetTabGroupCollection(*target_group);
+    if (group_coll) {
+      gfx::Range group_pre = group_coll->GetTabGroup()->ListTabs();
+      int sz_inside = 0;
+      for (int idx : tab_indices) {
+        if (idx >= static_cast<int>(group_pre.GetMin()) &&
+            idx < static_cast<int>(group_pre.GetMax())) {
+          ++sz_inside;
+        }
+      }
+      const int min_dest = static_cast<int>(group_pre.GetMin());
+      const int max_dest = static_cast<int>(group_pre.GetMax()) - sz_inside;
+      if (max_dest >= min_dest) {
+        to_index = std::clamp(to_index, min_dest, max_dest);
+      }
+    }
+  }
+
+  MoveTabsWithNotifications(
+      tab_indices, to_index,
+      base::BindOnce(&tabs::TabStripCollection::MoveTabsRecursive,
+                     base::Unretained(contents_data_.get()), tab_indices,
+                     to_index, target_group, enclosing, false,
+                     kRetainCollectionTypes));
+
+  NestedTabChange change(this, nested_id,
+                         NestedTabChange::MovedChange(old_index, to_index));
+  for (auto& observer : observers_) {
+    observer.OnNestedTabChanged(change);
+  }
+}
