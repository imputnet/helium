+namespace nested_tabs {
+class NestedTabData;
+class NestedTabVisualData;
+}  // namespace nested_tabs
+
+namespace tabs {
+
+// A collection for nested tabs. A nested collection always has an owner (depth
+// 0 nested collection is illegal). The owner tab lives INSIDE the NESTED
+// collection as its first child; subsequent children are the NESTED's members.
+//
+// Invariants:
+// - Owner tab is children()[0]. `data()->owner_tab()` returns its handle.
+// - NESTED has at least 2 children in steady state (owner + at least one
+//   member). A NESTED that shrinks to only the owner is auto-destroyed and the
+//   owner is promoted back to NESTED's parent collection at NESTED's former
+//   position.
+// - NESTED is never a direct child of Pinned.
+// - NESTED's owner is never pinned, never in a SPLIT.
+// - NESTED can contain SPLITs; SPLITs cannot contain NESTEDs.
+class NestedTabCollection : public TabCollection {
+ public:
+  explicit NestedTabCollection(nested_tabs::NestedTabId nested_id,
+                               nested_tabs::NestedTabVisualData visual_data,
+                               tabs::TabHandle owner_tab);
+  ~NestedTabCollection() override;
+  NestedTabCollection(const NestedTabCollection&) = delete;
+  NestedTabCollection& operator=(const NestedTabCollection&) = delete;
+
+  nested_tabs::NestedTabData* data() const { return nested_tab_data_.get(); }
+
+  // Returns the NestedTabId this collection is associated with.
+  nested_tabs::NestedTabId GetNestedTabId() const;
+
+  // Depth of this NESTED in the tree. A NESTED directly under UNPINNED/PINNED
+  // has depth 1. Each additional NESTED ancestor adds 1. Non-NESTED ancestors
+  // (TABSTRIP, PINNED, UNPINNED, GROUP) don't contribute.
+  size_t Depth() const;
+
+  bool IsCollapsed() const;
+  void SetIsCollapsed(bool is_collapsed);
+
+ private:
+  std::unique_ptr<nested_tabs::NestedTabData> nested_tab_data_;
+};
+
+}  // namespace tabs
+
+#endif  // COMPONENTS_TABS_PUBLIC_NESTED_TAB_COLLECTION_H_
