+void TabStripModel::ResolveCascade(tabs::TabInterface* root,
+                                   std::set<content::WebContents*>& expanded) {
+  // Pass 1: enumerate all tabs in cascade and find refusers.
+  auto* owned = contents_data_->GetNestedTabCollection(root);
+  std::vector<tabs::TabInterface*> all_tabs =
+      owned ? owned->GetTabsRecursive()
+            : std::vector<tabs::TabInterface*>{root};
+
+  base::flat_set<tabs::TabInterface*> must_stay;
+  for (auto* t : all_tabs) {
+    if (!IsTabClosable(t->GetContents())) {
+      must_stay.insert(t);
+    }
+  }
+
+  // Pass 2: propagate must_stay up through ancestors.
+  // For each refuser, walk parent → grandparent → ... until we exit `root`'s
+  // subtree. Mark each visited tab as must_stay.
+  base::flat_set<tabs::TabInterface*> cascade_members(all_tabs.begin(),
+                                                      all_tabs.end());
+  for (auto* refuser : must_stay) {
+    auto* current = refuser;
+    while (current && current != root) {
+      auto* parent_coll = current->GetParentCollection();
+      // Skip past SPLIT/GROUP to find the enclosing NESTED.
+      while (parent_coll &&
+             parent_coll->type() != tabs::TabCollection::Type::NESTED) {
+        parent_coll = parent_coll->GetParentCollection();
+      }
+      if (!parent_coll) {
+        break;  // no NESTED ancestor
+      }
+
+      auto* nested = static_cast<const tabs::NestedTabCollection*>(parent_coll);
+      auto* parent_tab = nested->data()->owner_tab().Get();
+      if (!parent_tab || !cascade_members.contains(parent_tab)) {
+        break;
+      }
+      must_stay.insert(parent_tab);
+      current = parent_tab;
+    }
+  }
+
+  // Pass 3: tabs not in must_stay → cascade-close them.
+  for (auto* t : all_tabs) {
+    if (!must_stay.contains(t)) {
+      expanded.insert(t->GetContents());
+    }
+  }
+
+  // If the root itself stays, fire OnTabCloseCancelled for the user-directed
+  // tab. The descendants weren't user-directed, so don't fire for them.
+  if (must_stay.contains(root)) {
+    for (auto& obs : observers_) {
+      obs.OnTabCloseCancelled(root);
+    }
+  }
+}
