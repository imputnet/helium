+void Browser::OnNestedTabChanged(const NestedTabChange& change) {
+  switch (change.type) {
+    case NestedTabChange::Type::kCreated: {
+      for (const auto& child : change.GetCreatedChange()->initial_children) {
+        UpdateNestedTabSessionData(child.Get(), change.nested_id);
+      }
+
+      UpdateNestedTabSessionVisualData(change.nested_id);
+      break;
+    }
+
+    case NestedTabChange::Type::kVisualsChanged: {
+      UpdateNestedTabSessionVisualData(change.nested_id);
+      break;
+    }
+
+    case NestedTabChange::Type::kMoved: {
+      // No need to do anything here since nested is still present and no
+      // visual/ownership information changed.
+      break;
+    }
+
+    case NestedTabChange::Type::kContentsChanged: {
+      for (const auto& child : change.GetContentsChange()->children_added) {
+        UpdateNestedTabSessionData(child.Get(), change.nested_id);
+      }
+      for (const auto& removed : change.GetContentsChange()->children_removed) {
+        UpdateNestedTabSessionData(removed.Get(), std::nullopt);
+      }
+      break;
+    }
+
+    case NestedTabChange::Type::kDestroyed: {
+      for (const auto& removed :
+           change.GetDestroyedChange()->orphaned_children) {
+        UpdateNestedTabSessionData(removed.Get(), std::nullopt);
+      }
+      break;
+    }
+  }
+}
