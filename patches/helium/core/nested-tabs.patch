+int TabStripModel::MaybeBumpIndexPastNested(int index) const {
+  if (index <= 0 || index > count()) {
+    return index;
+  }
+  tabs::TabInterface* prev_tab = GetTabAtIndex(index - 1);
+  if (!prev_tab) {
+    return index;
+  }
+  auto* nested = contents_data_->GetNestedTabCollection(prev_tab);
+  if (!nested) {
+    return index;
+  }
+  const int nested_end = (index - 1) + nested->TabCountRecursive();
+  return std::max(index, nested_end);
+}
