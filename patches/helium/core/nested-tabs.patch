+void VerticalTabView::OnPaintBorder(gfx::Canvas* canvas) {
+  views::View::OnPaintBorder(canvas);
+  if (!is_drop_target_) {
+    return;
+  }
+
+  const SkScalar corner_radius = SkIntToScalar(
+      GetLayoutConstant(LayoutConstant::kVerticalTabCornerRadius) +
+      (split_ ? GetInsets().height() : 0));
+
+  cc::PaintFlags flags;
+  flags.setStyle(cc::PaintFlags::kStroke_Style);
+  flags.setStrokeWidth(2);
+  flags.setAntiAlias(true);
+  flags.setColor(
+      GetColorProvider()->GetColor(ui::kColorFocusableBorderFocused));
+
+  // Inset by half stroke width so the stroke lives fully inside bounds.
+  gfx::Rect bounds = GetLocalBounds();
+  bounds.Inset(1);  // inset by 1 on all sides
+  SkRRect rrect = SkRRect::MakeRectXY(gfx::RectToSkRect(bounds),
+                                      corner_radius - 1, corner_radius - 1);
+  canvas->sk_canvas()->drawRRect(rrect, flags);
+}
