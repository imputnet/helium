+    const tab_groups::TabGroupId& group) const {
+  std::vector<SessionID> ids;
+  TabGroupModel* group_model = tab_strip_model_->group_model();
+  if (!group_model || !group_model->ContainsTabGroup(group)) {
+    // Group not present in this context (e.g. its local id changed after a
+    // saved-group restore opened it under a new id). Caller is responsible
+    // for resolving the current local id; we just bail safely here.
+    return ids;
+  }
+  TabGroup* tab_group = group_model->GetTabGroup(group);
+  gfx::Range range = tab_group->ListTabs();
+  ids.reserve(range.length());
+  for (uint32_t i = range.start(); i < range.end(); ++i) {
+    ids.push_back(GetSessionIdAtIndex(static_cast<int>(i)));
+  }
+  return ids;
