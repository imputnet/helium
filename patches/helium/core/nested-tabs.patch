+void TabRestoreServiceHelper::CreateHistoricalNestedSubtree(
+    LiveTabContext* context,
+    int parent_index) {
+  // Window version of the group thing below
+  if (closing_contexts_.contains(context)) {
+    return;
+  }
+  // If this subtree's parent is in a group that's being closed as a unit,
+  // skip emission. The group's historical entry (built by
+  // CreateHistoricalGroupImpl) already captures the full nested structure
+  // inside the group; emitting per-subtree entries on top would put
+  // duplicate entries on the restore stack and require multiple
+  // cmd-shift-t presses to recover the same group close.
+  if (auto group = context->GetTabGroupForTab(parent_index);
+      group && closing_groups_.contains(*group)) {
+    return;
+  }
+
+  auto root = NestedDfsHelper(context, parent_index, true);
+
+  if (root && !root->navigations.empty()) {
+    AddEntry(std::move(root), true, true);
+  }
+}
+
+std::unique_ptr<tab_restore::Tab> TabRestoreServiceHelper::NestedDfsHelper(
+    LiveTabContext* context,
+    int parent_index,
+    bool do_suppression_tracking) {
+  constexpr size_t kSubtreeCap = 24;
+
+  std::unique_ptr<Tab> root;
+  size_t emitted = 0;
+  std::stack<std::pair<Tab*, int>> s;  // (parent-in-tree, tabstrip-index)
+  s.push({nullptr, parent_index});
+
+  SessionID root_live_id = context->GetSessionIdAtIndex(parent_index);
+  std::set<SessionID>& descendants = closing_subtrees_[root_live_id];
+
+  while (!s.empty()) {
+    auto [parent, subject] = s.top();
+    s.pop();
+
+    LiveTab* live = context->GetLiveTabAt(subject);
+
+    if (do_suppression_tracking) {
+      // Mark for suppression regardless of cap.
+      SessionID live_id = context->GetSessionIdAtIndex(subject);
+      descendants.insert(live_id);
+    }
+
+    // Only build entry struct if under cap; still recurse for suppression.
+    Tab* this_in_tree = nullptr;
+    if (emitted < kSubtreeCap) {
+      auto t = std::make_unique<Tab>();
+      PopulateTab(t.get(), subject, context, live);
+      this_in_tree = t.get();
+      if (parent) {
+        parent->children.push_back(std::move(t));
+      } else {
+        root = std::move(t);
+      }
+      emitted++;
+    }
+
+    // Push children in reverse for pre-order DFS pop order.
+    for (int idx :
+         std::views::reverse(context->GetDirectChildIndices(subject))) {
+      // If we're past cap, pass nullptr as parent so children also get
+      // suppression-tracked but aren't attached to a tree node.
+      s.push({this_in_tree, idx});
+    }
+  }
+
+  return root;
+}
+
+void TabRestoreServiceHelper::NestedSubtreeClosed(SessionID parent_id) {
+  closing_subtrees_.erase(parent_id);
+}
+
+void TabRestoreServiceHelper::NestedSubtreeCloseStopped(SessionID parent_id) {
+  // TODO: Make this similar to `GroupClosedStopped` when that function is fixed
+  closing_subtrees_.erase(parent_id);
+}
