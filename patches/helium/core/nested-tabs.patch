+std::unique_ptr<views::View> VerticalNestedTabView::DetachChildView(
+    views::View* child_view) {
+  return RemoveChildViewT(child_view);
+}
+
+void VerticalNestedTabView::ResetCollectionNode() {
+  collection_node_ = nullptr;
+}
+
+void VerticalNestedTabView::OnDataChanged() {
+  auto coll = GetNestedTabCollectionFromNode(collection_node_);
+  bool new_is_collapsed = coll->data()->visual_data()->IsCollapsed();
+  if (new_is_collapsed != is_collapsed_) {
+    is_collapsed_ = new_is_collapsed;
+    if (!is_collapsed_) {
+      UpdateChildVisibilityForCollapseState(false);
+    }
+    InvalidateLayout();
+  }
+}
+
+void VerticalNestedTabView::UpdateChildVisibilityForCollapseState(
+    bool collapsed) {
+  if (!collection_node_) {
+    return;
+  }
+  const auto children = collection_node_->GetDirectChildren();
+  // Owner (index 0) is the NESTED's visible "header" and stays shown.
+  for (size_t i = 1; i < children.size(); ++i) {
+    children[i]->SetVisible(!collapsed);
+  }
+}
+
+void VerticalNestedTabView::OnAnimationEnded() {
+  if (is_collapsed_) {
+    UpdateChildVisibilityForCollapseState(true);
+  }
+}
