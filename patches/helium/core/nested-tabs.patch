+void TabStripModel::UnnestImpl(const nested_tabs::NestedTabId& nested_id) {
+  tabs::NestedTabCollection* nested_coll =
+      contents_data_->GetNestedTabCollection(nested_id);
+  CHECK(nested_coll);
+
+  tabs::TabHandle destroyed = nested_coll->data()->owner_tab();
+  std::vector<tabs::TabHandle> orphans;
+  for (const auto& child : nested_coll->GetChildren()) {
+    if (auto* t = std::get_if<std::unique_ptr<tabs::TabInterface>>(&child)) {
+      orphans.push_back((*t)->GetHandle());
+    } else {
+      auto* coll = std::get<std::unique_ptr<tabs::TabCollection>>(child).get();
+      if (coll->type() == tabs::TabCollection::Type::SPLIT) {
+        // Tabs inside SPLIT also lose their nesting affiliation under this
+        // NESTED, even though they live one layer deep in the storage tree.
+        for (const auto& split_child : coll->GetChildren()) {
+          if (auto* st = std::get_if<std::unique_ptr<tabs::TabInterface>>(
+                  &split_child)) {
+            orphans.push_back((*st)->GetHandle());
+          }
+        }
+      }
+      // Sub-NESTEDs: their tabs are still nested (just under a sub-owner that's
+      // now in grandparent). They didn't lose their nesting. Skip.
+    }
+  }
+
+  // Promote all children to NESTED's parent at NESTED's slot, then destroy
+  // the NESTED. Preserves child order: owner first (it's children[0]), then
+  // non-owner members in their existing order.
+  contents_data_->UnnestCollection(nested_coll);
+
+  observers_.Notify(&TabStripModelObserver::OnNestedTabChanged,
+                    NestedTabChange(this, nested_id,
+                                    NestedTabChange::DestroyedChange(
+                                        destroyed, std::move(orphans))));
+}
+
+void TabStripModel::TryCompletePendingCascade(content::WebContents* descendant,
+                                              bool cancelled) {
+  // First, walk pending_cascades_ and either cancel cascades (cancelled=true)
+  // or remove this descendant from any cascade that's waiting on it. Collect
+  // the parents of cascades that just emptied, DO NOT call CloseTabs from
+  // inside this loop. CloseTabs synchronously closes the parent, which fires
+  // its own WebContentsDestroyed → re-entrant call into this function →
+  // mutates pending_cascades_ → invalidates our outer iterator.
+  struct CompletedCascade {
+    content::WebContents* parent;
+    uint32_t close_types;
+    SessionID parent_session_id;
+  };
+  std::vector<CompletedCascade> completed;
+
+  for (auto it = pending_cascades_.begin(); it != pending_cascades_.end();) {
+    auto& pending = *it;
+    auto desc_it = pending->descendants.find(descendant);
+    if (desc_it == pending->descendants.end()) {
+      ++it;
+      continue;
+    }
+
+    if (cancelled) {
+      // User cancelled beforeunload for this descendant. Abort the entire
+      // cascade, parent stays alive. PendingCascade destructor releases
+      // all sibling observers automatically.
+      if ((*it)->close_types & TabCloseTypes::CLOSE_CREATE_HISTORICAL_TAB) {
+        delegate_->NestedSubtreeCloseStopped((*it)->parent_session_id);
+        // Owner won't destruct (the close was cancelled), so the observer
+        // must be torn down explicitly here.
+        nested_subtree_owner_observers_.erase((*it)->parent);
+      }
+      it = pending_cascades_.erase(it);
+      continue;
+    }
+
+    pending->descendants.erase(desc_it);
+
+    if (pending->descendants.empty()) {
+      completed.push_back({pending->parent.get(), pending->close_types,
+                           pending->parent_session_id});
+      it = pending_cascades_.erase(it);
+      continue;
+    }
+
+    ++it;
+  }
+
+  // Now safe to recurse. Re-entry into TryCompletePendingCascade from any of
+  // these CloseTabs calls will iterate a freshly-stable pending_cascades_.
+  for (auto& c : completed) {
+    if (c.parent) {
+      CloseTabs({c.parent}, c.close_types);
+      // NestedSubtreeClosed cleanup is fired by NestedSubtreeOwnerObserver
+      // when the owner's WebContents actually destructs. Firing it here
+      // would clear the suppression set before the owner's
+      // CreateHistoricalTab runs (the close may be deferred by an unload
+      // listener).
+    }
+  }
+}
+
+void TabStripModel::OnNestedSubtreeOwnerDestroyed(
+    content::WebContents* contents,
+    SessionID parent_session_id) {
+  delegate_->NestedSubtreeClosed(parent_session_id);
+  nested_subtree_owner_observers_.erase(contents);
+}
+
+std::optional<int> TabStripModel::GetParentIndex(int child_idx) const {
+  tabs::TabInterface* tab = GetTabAtIndex(child_idx);
+  CHECK(tab);
+
+  // Find the first enclosing NESTED whose owner is NOT `tab` itself
+  // (an owner's immediate parent IS its own NESTED, which isn't its parent
+  // conceptually).
+  for (const tabs::TabCollection* p = tab->GetParentCollection(); p;
+       p = p->GetParentCollection()) {
+    if (p->type() == tabs::TabCollection::Type::TABSTRIP) {
+      return std::nullopt;
+    }
+    if (p->type() != tabs::TabCollection::Type::NESTED) {
+      continue;
+    }
+    tabs::TabInterface* owner = static_cast<const tabs::NestedTabCollection*>(p)
+                                    ->data()
+                                    ->owner_tab()
+                                    .Get();
+    if (owner != tab) {
+      return GetIndexOfTab(owner);
+    }
+  }
+  return std::nullopt;
+}
+
+std::vector<int> TabStripModel::GetChildIndices(int parent_idx) const {
+  tabs::TabInterface* tab = GetTabAtIndex(parent_idx);
+  CHECK(tab);
+
+  std::vector<int> children;
+  if (tabs::NestedTabCollection* nested =
+          contents_data_->GetNestedTabCollection(tab)) {
+    // Skip children[0] (the owner itself) and only return non-owner members.
+    const auto& all_children = nested->GetChildren();
+    for (size_t i = 1; i < all_children.size(); ++i) {
+      const auto& child = all_children[i];
+      if (const auto& child_coll =
+              std::get_if<std::unique_ptr<tabs::TabCollection>>(&child)) {
+        tabs::TabCollection* coll = child_coll->get();
+        if (coll->type() == tabs::TabCollection::Type::SPLIT) {
+          for (const auto& split_child : coll->GetChildren()) {
+            if (auto scti = std::get_if<std::unique_ptr<tabs::TabInterface>>(
+                    &split_child)) {
+              children.push_back(GetIndexOfTab(scti->get()));
+            }
+          }
+        } else if (coll->type() == tabs::TabCollection::Type::NESTED) {
+          // Sub-NESTED's owner is conceptually a direct child of `parent`.
+          // Return the owner's index, not the bare collection.
+          tabs::TabInterface* owner =
+              static_cast<tabs::NestedTabCollection*>(coll)
+                  ->data()
+                  ->owner_tab()
+                  .Get();
+          children.push_back(GetIndexOfTab(owner));
+        }
+      } else {
+        children.push_back(GetIndexOfTab(
+            std::get<std::unique_ptr<tabs::TabInterface>>(child).get()));
+      }
+    }
+  } else {
+    return {};
+  }
+
+  return children;
+}
+
+bool TabStripModel::IsDescendantOfAny(int subject,
+                                      const std::set<int>& maybe_ancestor_idxs,
+                                      bool self_is_ancestor) const {
+  tabs::TabInterface* subject_tab = GetTabAtIndex(subject);
+  std::set<tabs::TabInterface*> ancestor_tabs =
+      maybe_ancestor_idxs | std::views::transform([&](auto idx) {
+        return this->GetTabAtIndex(idx);
+      }) |
+      std::views::filter([](auto tab) { return tab; }) |
+      std::ranges::to<std::set>();
+
+  if (!subject_tab || ancestor_tabs.empty()) {
+    return false;
+  }
+
+  if (ancestor_tabs.contains(subject_tab) && self_is_ancestor) {
+    return true;
+  }
+
+  for (const tabs::TabCollection* c = subject_tab->GetParentCollection(); c;
+       c = c->GetParentCollection()) {
+    if (c->type() != tabs::TabCollection::Type::NESTED) {
+      continue;
+    }
+    const auto* nested = static_cast<const tabs::NestedTabCollection*>(c);
+    tabs::TabInterface* nested_owner = nested->data()->owner_tab().Get();
+    // Subject's own NESTED isn't an ancestor that "owns" it.
+    if (nested_owner == subject_tab) {
+      continue;
+    }
+    if (ancestor_tabs.contains(nested_owner)) {
+      return true;
+    }
+  }
+
+  return false;
+}
+
+bool TabStripModel::IsSubtreeCollapsed(
+    nested_tabs::NestedTabId nested_id) const {
+  // View-layer callers can query during transient states (e.g., the NESTED
+  // is mid-attach to a destination tabstrip during a cross-window drag).
+  // Default to not-collapsed when the NESTED isn't visible to this model.
+  tabs::NestedTabCollection* ntc =
+      contents_data_->GetNestedTabCollection(nested_id);
+  return ntc && ntc->IsCollapsed();
+}
+
+void TabStripModel::SetSubtreeCollapsed(nested_tabs::NestedTabId nested_id,
+                                        bool is_collapsed) {
+  ReentrancyCheck reentrancy_check(&reentrancy_guard_);
+  SetSubtreeCollapsedImpl(nested_id, is_collapsed);
+  CompleteModelUpdateTransaction();
+}
+
+void TabStripModel::SetSubtreeCollapsedImpl(nested_tabs::NestedTabId nested_id,
+                                            bool is_collapsed) {
+  tabs::NestedTabCollection* ntc =
+      contents_data_->GetNestedTabCollection(nested_id);
+  CHECK(ntc);
+
+  bool should_notify = ntc->IsCollapsed() != is_collapsed;
+
+  if (should_notify) {
+    nested_tabs::NestedTabVisualData old = *ntc->data()->visual_data();
+    ntc->SetIsCollapsed(is_collapsed);
+    observers_.Notify(&TabStripModelObserver::OnNestedTabChanged,
+                      NestedTabChange(this, nested_id,
+                                      NestedTabChange::VisualsChange(
+                                          old, *ntc->data()->visual_data())));
+  }
