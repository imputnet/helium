+std::unique_ptr<SessionCommand> CreateNestedTabCommand(
+    SessionID tab_id,
+    std::optional<nested_tabs::NestedTabId> nested_id) {
+  NestedTabPayload payload = {0};
+  payload.tab_id = tab_id.id();
+  if (nested_id.has_value()) {
+    DCHECK(!nested_id.value().token().is_zero());
+    payload.maybe_nested = {.id_high = nested_id.value().token().high(),
+                            .id_low = nested_id.value().token().low()};
+    payload.has_nested = true;
+  }
+  return CreateSessionCommandForPayload(kCommandSetTabNested, payload);
+}
+
+std::unique_ptr<SessionCommand> CreateNestedTabDataUpdateCommand(
+    const nested_tabs::NestedTabId& nested_id,
+    const nested_tabs::NestedTabVisualData* nested_tab_visual_data,
+    const SessionID owner_session_id) {
+  base::Pickle pickle;
+  base::WriteTokenToPickle(&pickle, nested_id.token());
+
+  pickle.WriteBool(nested_tab_visual_data->IsCollapsed());
+  pickle.WriteInt(owner_session_id.id());
+
+  return std::make_unique<SessionCommand>(kCommandSetNestedTabData, pickle);
+}
