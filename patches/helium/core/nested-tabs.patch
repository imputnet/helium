+void RootTabCollectionNode::OnNestedTabChanged(const NestedTabChange& change) {
+  if (tab_strip_model_->closing_all()) {
+    return;
+  }
+
+  TabCollectionNode* owner_node = nullptr;
+  TabCollectionNode* nested_node = nullptr;
+
+  switch (change.type) {
+    case NestedTabChange::Type::kCreated:
+    case NestedTabChange::Type::kVisualsChanged: {
+      const auto* data = change.model->GetNestingData(change.nested_id);
+      if (!data) {
+        return;
+      }
+      owner_node = GetNodeForHandle(data->owner_tab());
+      nested_node = GetNodeForHandle(data->GetCollectionHandle());
+      break;
+    }
+    case NestedTabChange::Type::kDestroyed: {
+      const auto* destroyed = change.GetDestroyedChange();
+      if (!destroyed) {
+        return;
+      }
+      owner_node = GetNodeForHandle(destroyed->former_owner);
+      break;
+    }
+    default:
+      return;  // kContentsChanged, kMoved: no chevron/dim impact today
+  }
+
+  if (nested_node) {
+    nested_node->NotifyDataChanged();
+  }
+  if (owner_node) {
+    owner_node->NotifyDataChanged();
+  }
+}
