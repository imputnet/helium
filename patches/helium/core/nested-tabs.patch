+views::ProposedLayout VerticalNestedTabView::CalculateProposedLayout(
+    const views::SizeBounds& size_bounds) const {
+  views::ProposedLayout layouts;
+  int width = 0;
+  int height = 0;
+
+  const std::vector<views::View*> children =
+      collection_node_ ? collection_node_->GetDirectChildren()
+                       : std::vector<views::View*>();
+
+  // Owner (first child) renders flush at the top; subsequent children get the
+  // NESTED indent. When collapsed, the owner stays at full bounds (it's the
+  // visible "header"); non-owner children animate to zero height.
+  for (size_t i = 0; i < children.size(); ++i) {
+    auto* child = children[i];
+    const bool is_owner = (i == 0);
+
+    const int strip_indent =
+        GetTabStripCollapseState() ==
+                tabs::VerticalTabStripCollapseState::kExpanded
+            ? kNestedIndent
+            : 0;
+    const int x = is_owner ? 0 : strip_indent;
+    const int avail_w =
+        size_bounds.width().is_bounded() ? size_bounds.width().value() - x : 0;
+
+    gfx::Rect bounds;
+    if (is_collapsed_ && !is_owner) {
+      // Target: zero-height row stacked under owner. Bounds interpolate from
+      // each child's current rect, producing a slide-up-and-shrink animation.
+      bounds = gfx::Rect(x, height, avail_w, 0);
+    } else {
+      views::SizeBounds child_size_bounds(
+          size_bounds.width().is_bounded() ? avail_w : size_bounds.width(), {});
+      bounds = gfx::Rect(child->GetPreferredSize(child_size_bounds));
+      bounds.set_x(x);
+      bounds.set_y(height);
+      if (size_bounds.width().is_bounded()) {
+        bounds.set_width(avail_w);
+      }
+      height += bounds.height() + kTabVerticalPadding;
+    }
+
+    layouts.child_layouts.emplace_back(child, child->GetVisible(), bounds);
+    width = std::max(width, bounds.width() + bounds.x());
+  }
+  if (!children.empty()) {
+    height -= kTabVerticalPadding;
+  }
+
+  layouts.host_size = gfx::Size(width, height);
+  return layouts;
+}
