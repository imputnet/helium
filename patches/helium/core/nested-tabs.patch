+NestedTabCollection* TabStripCollection::GetNestedTabCollection(
+    const TabInterface* tab) {
+  // A tab owns a NESTED iff its direct parent is a NESTED whose owner_tab
+  // points back to it (owner is the NESTED's children[0]).
+  const TabCollection* parent = tab->GetParentCollection();
+  if (!parent || parent->type() != TabCollection::Type::NESTED) {
+    return nullptr;
+  }
+  auto* nested = const_cast<NestedTabCollection*>(
+      static_cast<const NestedTabCollection*>(parent));
+  return nested->data()->owner_tab().Get() == tab ? nested : nullptr;
+}
+
+NestedTabCollection* TabStripCollection::GetNestedTabCollection(
+    const nested_tabs::NestedTabId& nested_id) {
+  auto it = nested_mapping_.find(nested_id);
+  if (it != nested_mapping_.end()) {
+    return it->second;
+  }
+  return nullptr;
+}
+
+TabStripCollection::NestedCreationResult
+TabStripCollection::FindOrCreateNestedFor(
+    TabInterface* parent_tab,
+    std::optional<nested_tabs::NestedTabVisualData> visual_data,
+    std::optional<nested_tabs::NestedTabId> id_override) {
+  CHECK(!parent_tab->IsSplit())
+      << "It is illegal to create a NESTED inside a SPLIT";
+  CHECK(!parent_tab->IsPinned()) << "Cannot create a NESTED on a pinned tab";
+
+  NestedTabCollection* existing = GetNestedTabCollection(parent_tab);
+  if (existing) {
+    return {existing, false};
+  }
+
+  // Insert an empty NESTED at parent_tab's slot, then move parent_tab into
+  // it as children[0]. The NESTED is transiently empty between these steps;
+  // ValidateData only runs at CompleteModelUpdateTransaction so invariants
+  // hold by then.
+  TabCollection* parent_coll = parent_tab->GetParentCollection(GetPassKey());
+  CHECK(parent_coll);
+  const size_t owner_idx = parent_coll->GetIndexOfTab(parent_tab).value();
+
+  auto coll = std::make_unique<tabs::NestedTabCollection>(
+      id_override.value_or(nested_tabs::NestedTabId::GenerateNew()),
+      visual_data.value_or(nested_tabs::NestedTabVisualData{}),
+      parent_tab->GetHandle());
+  auto ptr = coll.get();
+
+  AddTabCollectionImpl(std::move(coll), {parent_coll->GetHandle(), owner_idx});
+
+  TabCollection::Position owner_pos{ptr->GetHandle(), 0};
+  MoveTabImpl(parent_tab, owner_pos);
+
+  return {ptr, true};
+}
+
+std::optional<TabStripCollection::NestedDestruction>
+TabStripCollection::MoveTabToNested(TabInterface* tab,
+                                    const nested_tabs::NestedTabId& id,
+                                    std::optional<size_t> target_child_idx) {
+  NestedTabCollection* coll = GetNestedTabCollection(id);
+  CHECK(coll);
+  CHECK(coll->data()->owner_tab().Get() != tab);
+
+  return MoveTabToCollectionWithNestedCleanup(tab, coll, target_child_idx);
+}
+
+std::optional<TabStripCollection::NestedDestruction>
+TabStripCollection::MoveTabToTopLevel(TabInterface* tab,
+                                      std::optional<size_t> target_child_idx) {
+  TabCollection* coll = tab->GetParentCollection(GetPassKey());
+  while (coll->GetParentCollection() &&
+         coll->GetParentCollection()->type() != Type::TABSTRIP) {
+    coll = coll->GetParentCollection();
+  }
+  return MoveTabToCollectionWithNestedCleanup(tab, coll, target_child_idx);
+}
+
+std::optional<TabStripCollection::NestedDestruction>
+TabStripCollection::MoveTabToCollectionWithNestedCleanup(
+    TabInterface* tab,
+    TabCollection* coll,
+    std::optional<size_t> target_child_idx) {
+  TabCollection* old_tab_parent = tab->GetParentCollection(GetPassKey());
+  NestedTabCollection* old_tab_nested = GetNestedTabCollection(tab);
+
+  size_t tgt_idx =
+      target_child_idx
+          .transform([&](auto i) { return std::min(i, coll->ChildCount()); })
+          .value_or(coll->ChildCount());
+  TabCollection::Position tp = {coll->GetHandle(), tgt_idx};
+
+  if (old_tab_nested) {
+    // `tab` owns a NESTED; move the whole NESTED as a unit (owner rides
+    // along as children[0]).
+    TabCollection* grandparent = old_tab_nested->GetParentCollection();
+    MoveCollectionImpl(old_tab_nested, tp);
+    if (grandparent && grandparent->type() == Type::NESTED) {
+      return MaybeDestroyNestedWithOnlyOwner(
+          static_cast<NestedTabCollection*>(grandparent));
+    }
+    return std::nullopt;
+  }
+
+  if (tab->IsSplit()) {
+    TabCollection* split_grandparent = old_tab_parent->GetParentCollection();
+    MoveCollectionImpl(old_tab_parent, tp);
+    if (split_grandparent && split_grandparent->type() == Type::NESTED) {
+      return MaybeDestroyNestedWithOnlyOwner(
+          static_cast<NestedTabCollection*>(split_grandparent));
+    }
+    return std::nullopt;
+  }
+
+  MoveTabImpl(tab, tp);
+
+  if (old_tab_parent->type() == Type::NESTED) {
+    return MaybeDestroyNestedWithOnlyOwner(
+        static_cast<NestedTabCollection*>(old_tab_parent));
+  }
+  return std::nullopt;
+}
+
+void TabStripCollection::UnnestCollection(NestedTabCollection* nested) {
+  TabCollection* parent = nested->GetParentCollection();
+  CHECK(parent);
+  size_t insertion_idx = parent->GetIndexOfCollection(nested).value();
+
+  // Snapshot children before mutating. Iteration order is preserved (owner is
+  // first), so the resulting layout in `parent` is [owner, c1, c2, ...] at
+  // `insertion_idx`.
+  std::vector<std::variant<TabInterface*, TabCollection*>> snapshot;
+  for (const auto& child : nested->GetChildren()) {
+    if (auto* t = std::get_if<std::unique_ptr<TabInterface>>(&child)) {
+      snapshot.emplace_back(t->get());
+    } else {
+      snapshot.emplace_back(
+          std::get<std::unique_ptr<TabCollection>>(child).get());
+    }
+  }
+
+  for (auto& item : snapshot) {
+    TabCollection::Position pos{parent->GetHandle(), insertion_idx};
+    if (auto** t = std::get_if<TabInterface*>(&item)) {
+      // Low-level move (skips the "owner moves with NESTED" semantic; the
+      // NESTED is being torn down here).
+      MoveTabImpl(*t, pos);
+    } else {
+      MoveCollectionImpl(std::get<TabCollection*>(item), pos);
+    }
+    insertion_idx++;
+  }
+
+  RemoveTabCollectionImpl(nested);
+}
