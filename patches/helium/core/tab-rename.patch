+#ifndef CHROME_BROWSER_UI_VIEWS_TABS_TAB_RENAME_DIALOG_H_
+#define CHROME_BROWSER_UI_VIEWS_TABS_TAB_RENAME_DIALOG_H_
+
+#include <memory>
+
+#include "base/memory/raw_ptr.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/tabs/tab_custom_titles.h"
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "content/public/browser/invalidate_type.h"
+#include "content/public/browser/navigation_entry.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/gfx/geometry/insets.h"
+#include "ui/gfx/geometry/size.h"
+#include "ui/views/controls/textfield/textfield.h"
+#include "ui/views/layout/box_layout.h"
+#include "ui/views/widget/widget.h"
+#include "ui/views/window/dialog_delegate.h"
+
+// A simple modal dialog that lets the user rename the active tab.
+// Shows the current custom title (or page title) as the initial value.
+// On Accept, stores the title in tab_custom_titles and applies it to the
+// current NavigationEntry so the tab strip reflects it immediately.
+class TabRenameView : public views::DialogDelegateView {
+ public:
+  static void Show(Browser* browser, int tab_index) {
+    auto* dialog = new TabRenameView(browser, tab_index);
+    views::Widget::CreateWindowWithContext(
+        dialog, browser->window()->GetNativeWindow())
+        ->Show();
+  }
+
+  TabRenameView(Browser* browser, int tab_index)
+      : browser_(browser), tab_index_(tab_index) {
+    SetTitle(u"Rename Tab");
+    SetModalType(ui::mojom::ModalType::kWindow);
+    SetLayoutManager(std::make_unique<views::BoxLayout>(
+        views::BoxLayout::Orientation::kVertical, gfx::Insets(12), 8));
+
+    textfield_ = AddChildView(std::make_unique<views::Textfield>());
+    textfield_->SetPreferredSize(gfx::Size(320, 32));
+    textfield_->SetPlaceholderText(u"Tab name");
+
+    content::WebContents* wc =
+        browser->tab_strip_model()->GetWebContentsAt(tab_index);
+    if (wc) {
+      const std::u16string* custom = tab_custom_titles::GetTitle(wc);
+      textfield_->SetText(custom ? *custom : wc->GetTitle());
+      textfield_->SelectAll(true);
+    }
+  }
+
+  bool Accept() override {
+    content::WebContents* wc =
+        browser_->tab_strip_model()->GetWebContentsAt(tab_index_);
+    if (!wc)
+      return true;
+    const std::u16string title = textfield_->GetText();
+    tab_custom_titles::SetTitle(wc, title);
+    if (!title.empty()) {
+      if (auto* entry = wc->GetController().GetVisibleEntry())
+        entry->SetTitle(title);
+    }
+    wc->NotifyNavigationStateChanged(content::INVALIDATE_TYPE_TITLE);
+    return true;
+  }
+
+ private:
+  raw_ptr<Browser> browser_;
+  int tab_index_;
+  raw_ptr<views::Textfield> textfield_;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_TABS_TAB_RENAME_DIALOG_H_
