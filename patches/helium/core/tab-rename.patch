+#ifndef CHROME_BROWSER_UI_TABS_TAB_CUSTOM_TITLES_H_
+#define CHROME_BROWSER_UI_TABS_TAB_CUSTOM_TITLES_H_
+
+#include <string>
+
+#include "base/containers/flat_map.h"
+#include "base/no_destructor.h"
+#include "content/public/browser/web_contents.h"
+
+// Stores user-defined custom tab titles keyed by WebContents*.
+// Valid for the lifetime of each tab's WebContents.
+namespace tab_custom_titles {
+
+inline base::flat_map<content::WebContents*, std::u16string>& GetMap() {
+  static base::NoDestructor<
+      base::flat_map<content::WebContents*, std::u16string>>
+      map;
+  return *map;
+}
+
+inline const std::u16string* GetTitle(content::WebContents* wc) {
+  const auto& map = GetMap();
+  const auto it = map.find(wc);
+  return (it != map.end() && !it->second.empty()) ? &it->second : nullptr;
+}
+
+inline void SetTitle(content::WebContents* wc, const std::u16string& title) {
+  if (title.empty())
+    GetMap().erase(wc);
+  else
+    GetMap()[wc] = title;
+}
+
+}  // namespace tab_custom_titles
+
+#endif  // CHROME_BROWSER_UI_TABS_TAB_CUSTOM_TITLES_H_
