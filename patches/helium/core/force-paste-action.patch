+void ForcePaste(BrowserWindowInterface* browser) {
+  if (!browser) {
+    return;
+  }
+  ForcePaste(browser->GetTabStripModel()->GetActiveWebContents());
+}
+
+void ForcePaste(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return;
+  }
+
+  content::RenderFrameHost* focused_frame = web_contents->GetFocusedFrame();
+  if (!focused_frame) {
+    return;
+  }
+
+  ui::Clipboard::GetForCurrentThread()->ReadText(
+      ui::ClipboardBuffer::kCopyPaste,
+      content::CreateDataEndpoint(*focused_frame),
+      base::BindOnce(&OnForcePasteTextRead, web_contents->GetWeakPtr(),
+                     focused_frame->GetGlobalId()));
+}
