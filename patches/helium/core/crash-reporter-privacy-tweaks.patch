+std::string SanitizeFeatureList(std::string_view feature_list) {
+  std::vector<std::string> sanitized_features;
+  for (std::string feature :
+       base::SplitString(feature_list, ",", base::TRIM_WHITESPACE,
+                         base::SPLIT_WANT_NONEMPTY)) {
+    const size_t separator = feature.find_first_of("<:");
+    if (separator != std::string::npos) {
+      feature.resize(separator);
+    }
+    bool valid = !feature.empty();
+    for (size_t i = 0; valid && i < feature.size(); ++i) {
+      const char c = feature[i];
+      valid = base::IsAsciiAlphaNumeric(c) || c == '_' || c == '-' ||
+              c == '.' || (i == 0 && c == '*');
+    }
+    if (valid) {
+      sanitized_features.push_back(feature);
+    }
+  }
+  return base::JoinString(sanitized_features, ",");
+}
